def get_body_component_path(body):
    names = []

    current = body
    visited = {}

    for i in range(20):
        if current is None:
            break

        try:
            key = safe_str(id(current))
            if key in visited:
                break
            visited[key] = True
        except:
            pass

        try:
            name = get_name(current)
            if name != "":
                names.append(name)
        except:
            pass

        parent = None

        for attr in ["Parent", "Component", "Master"]:
            try:
                parent = getattr(current, attr)
                if parent is not None:
                    break
            except:
                parent = None

        if parent is None:
            try:
                parent = current.GetParent()
            except:
                parent = None

        current = parent

    return "/".join(names)

def path_contains_database_key(path_text):
    if not SKIP_DATABASE_COMPONENT_PATH_MATCHES:
        return False

    p = safe_str(path_text).upper()
    if p == "":
        return False
    for key in DATABASE_FILE_KEYS:
        if key != "" and key in p:
            return True
    for key in DATABASE_BODY_NAMES:
        if key != "" and key in p:
            return True

    return False

def should_skip_target_body(body, body_name):
    if SKIP_ALREADY_REPLACED and starts_with_any(body_name, ["REPLACED_BY_DB_"]):
        return True
    if SKIP_IMPORTED_REPLACEMENT_BODIES and starts_with_any(body_name, ["DB_REPLACEMENT_", "DB_IMPORTED_", "DB_TEMPLATE_", "DB_SOURCE_ORIGINAL_"]):
        return True
    if is_macro_generated_body_name(body_name):
        return True
    if SKIP_EXISTING_DATABASE_ITEM_BODIES:
        component_path = get_body_component_path(body)
        if path_contains_database_key(component_path):
            if not CURRENT_SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS:
                return True
            else:
                append_full_txt_log(
                    "SECOND_PASS_DATABASE_PATH_CANDIDATE_ALLOWED",
                    "body={} | component_path={}".format(body_name, component_path)
                )

        name_upper = safe_str(body_name).upper()

        if name_upper in DATABASE_BODY_NAMES:
            if not CURRENT_SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS:
                return True
            else:
                append_full_txt_log(
                    "SECOND_PASS_DATABASE_NAME_CANDIDATE_ALLOWED",
                    "body={} | name_upper={}".format(body_name, name_upper)
                )
    return False

def get_bodies_from_paste_result(paste_result, before_bodies):
    """
    V11: Returns bodies created by Paste.FromClipboard().

    The V10 failure was: Paste.FromClipboard returned something, but no pasted body
    was detected. In some SpaceClaim builds the pasted object is exposed through
    GetCreated[DesignBody](), CreatedBodies, CreatedComponents, or only by a
    refreshed document snapshot. This function tries all paths.
    """
    bodies = []
    keys = {}

    before_tokens = {}
    try:
        before_tokens = make_body_snapshot_tokens(before_bodies)
    except:
        before_tokens = {}

    def add_body(b):
        try:
            if b is None:
                return
            add_body_unique_by_identity(b, bodies, keys)
        except:
            pass

    # Direct GetCreated paths.
    try:
        for b in paste_result.GetCreated[DesignBody]():
            add_body(b)
    except:
        pass

    try:
        for b in paste_result.GetCreated[IDesignBody]():
            add_body(b)
    except:
        pass

    # Common properties.
    for attr in ["CreatedBodies", "Bodies", "CreatedDesignBodies"]:
        try:
            values = getattr(paste_result, attr)
            if values is not None:
                for b in values:
                    add_body(b)
        except:
            pass

    # CreatedObjects selection path.
    try:
        created = paste_result.CreatedObjects
        try:
            sel = Selection.Create(created)
            try:
                for b in list(sel.GetItems[DesignBody]()):
                    add_body(b)
            except:
                pass
            try:
                for b in list(sel.GetItems[IDesignBody]()):
                    add_body(b)
            except:
                pass
        except:
            pass
    except:
        pass

    # Created components may contain bodies.
    created_components = []
    try:
        for c in paste_result.GetCreated[Component]():
            created_components.append(c)
    except:
        pass

    for attr in ["CreatedComponents", "Components"]:
        try:
            values = getattr(paste_result, attr)
            if values is not None:
                for c in values:
                    created_components.append(c)
        except:
            pass

    for c in created_components:
        collect_bodies_from_component_like(c, bodies, keys)

    # Snapshot fallback by robust token, not wrapper identity.
    try:
        after_bodies = get_all_bodies()
        for b in after_bodies:
            try:
                token = body_snapshot_token(b)
                if token in before_tokens:
                    continue
                add_body(b)
            except:
                pass
    except:
        pass

    return bodies

def show_item_for_copy(item):
    try:
        selection = Selection.Create(item)
        ViewHelper.SetObjectVisibility(selection, VisibilityType.Show, False)
        return True
    except:
        return False

def copy_body_in_place_as_independent(body):

    if body is None:
        return None, "source body is None"

    if FORCE_TEMPLATE_VISIBLE_BEFORE_COPY:
        show_item_for_copy(body)

    before_bodies = get_all_bodies()
    errors = []

    # Method 1: clipboard API used in V10.
    try:
        result = Copy.ToClipboard(Selection.Create(body))
        try:
            if hasattr(result, "Success") and not result.Success:
                errors.append("Copy.ToClipboard Success=False")
        except:
            pass

        paste_result = Paste.FromClipboard()
        if paste_result is None:
            errors.append("Paste.FromClipboard returned None")
        else:
            created_bodies = get_bodies_from_paste_result(paste_result, before_bodies)
            if len(created_bodies) > 0:
                best = choose_best_copied_body(created_bodies)
                return best, ""
            errors.append("clipboard paste created no detected bodies")
    except Exception as e:
        errors.append("clipboard copy/paste failed: " + safe_str(e))

    # Method 2: some SpaceClaim builds expose Copy.Execute.
    try:
        before_bodies = get_all_bodies()
        result = Copy.Execute(Selection.Create(body))
        created_bodies = get_bodies_from_paste_result(result, before_bodies)
        if len(created_bodies) > 0:
            best = choose_best_copied_body(created_bodies)
            return best, ""
        errors.append("Copy.Execute created no detected bodies")
    except Exception as e:
        errors.append("Copy.Execute failed: " + safe_str(e))

    return None, " | ".join(errors)

def choose_best_copied_body(created_bodies):
    best = None
    for b in created_bodies:
        try:
            sig = build_body_signature(b)
            if sig.get("body_role_guess") == "treated_surface":
                best = b
                break
        except:
            pass
    if best is None and len(created_bodies) > 0:
        best = created_bodies[0]
    return best

def cleanup_linked_imported_set_after_bake(new_bodies, db_row=None, target_sig=None):
    """
    Removes or hides the linked imported database set after the independent final copy exists.
    This prevents later imports of the same database file from moving previous replacements.
    """
    action = safe_str(IMPORTED_SET_AFTER_BAKE_ACTION).upper()

    if action == "":
        action = "DELETE"

    for b in new_bodies:
        try:
            old_name = get_name(b)
            db_key = "DB"
            target_name = "TARGET"

            if db_row is not None:
                db_key = safe_str(db_row.get("file_key", "DB"))
            if target_sig is not None:
                target_name = make_safe_name(target_sig.get("body_name", "TARGET"))

            set_name(b, "DB_LINKED_IMPORT_{}_FOR_{}_{}".format(db_key, target_name, old_name))
        except:
            pass

        if action == "DELETE":
            delete_item(b)
        elif action == "HIDE":
            hide_item(b)
        else:
            pass

def cleanup_imported_non_replacement_bodies(new_bodies, replacement_body, db_row=None, target_sig=None):
    """
    Handles imported support bodies, normally the dirty original solid that comes with the bank file.

    V3 default is HIDE, not DELETE. Deleting the source original can affect dependent imports
    of the same database item in the same SpaceClaim session and break the next positioning.
    """
    action = safe_str(IMPORTED_NON_REPLACEMENT_BODY_ACTION).upper()

    for b in new_bodies:
        try:
            if b == replacement_body:
                continue
        except:
            pass

        try:
            old_name = get_name(b)
            db_key = "DB"
            target_name = "TARGET"

            if db_row is not None:
                db_key = safe_str(db_row.get("file_key", "DB"))
            if target_sig is not None:
                # Use a compact instance label if present; avoids name collision when many
                # occurrences have the same original body name.
                target_name = make_target_instance_label(target_sig, "SRC")

            set_name(b, "DB_SOURCE_ORIGINAL_{}_FOR_{}_{}".format(db_key, target_name, old_name))
        except:
            pass

        if action == "HIDE":
            hide_item(b)
        elif action == "DELETE":
            # Kept as an option, but not recommended during industrial validation.
            delete_item(b)
        else:
            pass

def apply_original_after_replacement_action(target_body, db_row):
    action = safe_str(ORIGINAL_AFTER_REPLACEMENT).upper()
    if action == "":
        action = "KEEP"

    # V16: never mutate the original structural body unless explicitly unlocked.
    # This is important for assemblies with repeated/component instances, because
    # deleting one occurrence can delete or invalidate sibling occurrences.
    if action in ["DELETE", "HIDE"] and not ALLOW_ORIGINAL_TARGET_DELETE_OR_HIDE:
        append_full_txt_log(
            "ORIGINAL_TARGET_ACTION_FORCED_KEEP",
            "requested_action={} | target={} | db_key={}".format(
                action,
                body_summary_for_debug(target_body),
                safe_str(db_row.get("file_key", "DB"))
            )
        )
        return "KEEP"

    if TAG_TARGET_ORIGINAL_BODY:
        old_name = get_name(target_body)
        new_name = "REPLACED_BY_DB_{}_{}".format(safe_str(db_row.get("file_key", "DB")), old_name)
        set_name(target_body, new_name)

    if action == "HIDE":
        hide_item(target_body)
        return "HIDE"

    if action == "DELETE":
        delete_item(target_body)
        return "DELETE"

    return "KEEP"

def replace_one_target_body(target_body, target_sig, db_row, score, match_index, target_frame_snapshot=None, target_plan_id=""):
    db_file_path, path_source = resolve_database_item_file_path(db_row)
    temp_planes = []

    log_row = {
        "datetime": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "target_body_name": target_sig.get("body_name"),
        "target_action": "",
        "accepted": 1,
        "replaced": 0,
        "score": score,
        "db_file_key": db_row.get("file_key", ""),
        "db_body_name": db_row.get("body_name", ""),
        "db_pair_id": db_row.get("pair_id", ""),
        "db_item_file_path": db_file_path,
        "db_item_file_path_source": path_source,
        "replacement_body_name": "",
        "import_method": "",
        "new_bodies_count": "",
        "transformed_items_count": "",
        "transform_delta_x_mm": "",
        "transform_delta_y_mm": "",
        "transform_delta_z_mm": "",
        "transform_rotation_1_rad": "",
        "transform_rotation_2_rad": "",
        "target_plan_id": target_plan_id,
        "target_center_x_mm": "",
        "target_center_y_mm": "",
        "target_center_z_mm": "",
        "source_frame_source": "",
        "source_original_body_name": "",
        "target_axis_quality": "",
        "target_ref_warning": "",
        "orientation_signs": "",
        "orientation_score_mean_mm": "",
        "orientation_score_max_mm": "",
        "orientation_warning": "",
        "baked_copy_created": "",
        "baked_replacement_body_name": "",
        "imported_set_after_bake_action": "",
        "individual_instance_mode": "V9_PLANE_FRAME_SOURCE_AND_STRICT_IMPORT",
        "error_message": ""
    }

    try:
        debug_event(
            "REPLACE_START",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            target_body,
            target_frame_snapshot,
            "Starting replacement for planned target",
            "target={} | db_file_path={} | score={}".format(body_summary_for_debug(target_body), db_file_path, score)
        )

        # This is the dictionary/snapshot of the original spatial position before imports, hides or renames.
        target_frame = clone_frame(target_frame_snapshot)

        if target_frame is None:
            target_frame = compute_ordered_reference_frame_from_body(target_body)

        if target_frame is None:
            debug_event("TARGET_FRAME_FAILED", target_plan_id, target_body, target_sig, db_row, target_body, None, "Could not compute target frame", "")
            raise Exception("Could not compute target reference frame")

        debug_event("TARGET_FRAME_OK", target_plan_id, target_body, target_sig, db_row, target_body, target_frame, "Target frame available before import", "")

        log_row["target_axis_quality"] = target_frame.get("axis_quality", "")
        log_row["target_ref_warning"] = target_frame.get("warning", "")

        c = target_frame.get("center")
        if c is not None:
            log_row["target_center_x_mm"] = c[0]
            log_row["target_center_y_mm"] = c[1]
            log_row["target_center_z_mm"] = c[2]

        temp_planes = create_temporary_target_planes(target_body, target_frame, match_index)

        if DRY_RUN:
            print("DRY_RUN: replacement skipped for target {}".format(target_sig.get("body_name")))
            log_row["target_action"] = "DRY_RUN"
            append_log(log_row)
            delete_temporary_planes(temp_planes)
            return True

        # This is the main positioning fix for repeated database items.
        import_file_path = db_file_path
        import_path_source = path_source

        if USE_UNIQUE_TEMP_IMPORT_COPY_PER_PLAN:
            import_file_path, import_path_source = make_unique_temp_import_file(
                db_file_path,
                db_row,
                target_plan_id
            )

        log_row["db_item_file_path"] = import_file_path
        log_row["db_item_file_path_source"] = import_path_source

        debug_event(
            "IMPORT_START",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            None,
            None,
            "Importing database item",
            "original={} | insert_path={} | source={}".format(db_file_path, import_file_path, import_path_source)
        )

        new_bodies, import_method = insert_database_file_into_current_document(import_file_path)
        cleanup_unique_temp_import_file(import_file_path, db_file_path)

        log_row["import_method"] = import_method
        log_row["new_bodies_count"] = len(new_bodies)

        if DEBUG_LOG_IMPORT_BODY_DETAILS:
            debug_event("IMPORT_DONE", target_plan_id, target_body, target_sig, db_row, None, None, "Imported database item", "method={} | new_bodies_count={} | bodies={}".format(import_method, len(new_bodies), bodies_summary_for_debug(new_bodies)))

        if len(new_bodies) == 0:
            raise Exception("No new bodies were detected after database item import")

        replacement_body = choose_imported_treated_surface_body(new_bodies, db_row)
        if replacement_body is None:
            debug_event("CHOOSE_REPLACEMENT_FAILED", target_plan_id, target_body, target_sig, db_row, None, None, "Could not identify imported treated_surface body", bodies_summary_for_debug(new_bodies))
            raise Exception("Could not identify imported treated_surface body")

        imported_original_body = choose_imported_original_body(new_bodies, db_row)

        debug_event("CHOOSE_IMPORTED_BODIES", target_plan_id, target_body, target_sig, db_row, replacement_body, None, "Imported bodies selected", "replacement={} | imported_original={}".format(body_summary_for_debug(replacement_body), body_summary_for_debug(imported_original_body)))

        # This is the plane/frame-based workflow: the frame of the target instance
        # and the frame of the bank item are created by the same rule/function.
        # Recomputing the source frame from imported bodies is now only a fallback,
        # because repeated imports may expose stale/dependent SpaceClaim bodies.
        source_frame = None
        source_frame_source = ""

        if ABORT_IF_IMPORTED_SELECTION_IS_OLD_MACRO_BODY:
            if replacement_body is not None and is_macro_generated_body_name(get_name(replacement_body)):
                raise Exception("Selected replacement body is an old macro body, not a fresh import: " + get_name(replacement_body))
            if imported_original_body is not None and is_macro_generated_body_name(get_name(imported_original_body)):
                raise Exception("Selected original source body is an old macro body, not a fresh import: " + get_name(imported_original_body))

        if USE_DATABASE_ROW_FRAME_AS_SOURCE_FIRST:
            source_frame = frame_from_database_row(db_row)
            if source_frame is not None:
                source_frame_source = "database_row_plane_frame"

        if imported_original_body is not None:
            log_row["source_original_body_name"] = get_name(imported_original_body)

        if source_frame is None and imported_original_body is not None:
            source_frame = compute_ordered_reference_frame_from_body(imported_original_body)
            if source_frame is not None:
                source_frame_source = "imported_original_body_fallback"

        if source_frame is None:
            source_frame = compute_ordered_reference_frame_from_body(replacement_body)
            if source_frame is not None:
                source_frame_source = "imported_replacement_surface_fallback"

        if source_frame is None:
            debug_event("SOURCE_FRAME_FAILED", target_plan_id, target_body, target_sig, db_row, imported_original_body, None, "Could not compute source frame", "replacement={}".format(body_summary_for_debug(replacement_body)))
            raise Exception("Could not compute source reference frame for imported database item")

        debug_event("SOURCE_FRAME_OK", target_plan_id, target_body, target_sig, db_row, imported_original_body, source_frame, "Source frame computed", "source_frame_source={}".format(source_frame_source))

        log_row["source_frame_source"] = source_frame_source

        orientation_result = choose_best_target_frame_variant_by_vertex_cloud(
            imported_original_body,
            target_body,
            source_frame,
            target_frame
        )

        target_frame_for_alignment = orientation_result.get("frame", target_frame)

        log_row["orientation_signs"] = orientation_result.get("signs", "")
        log_row["orientation_score_mean_mm"] = orientation_result.get("mean_score", "")
        log_row["orientation_score_max_mm"] = orientation_result.get("max_score", "")
        log_row["orientation_warning"] = orientation_result.get("warning", "")

        debug_event("ORIENTATION_SELECTED", target_plan_id, target_body, target_sig, db_row, replacement_body, target_frame_for_alignment, "Orientation variant selected", "signs={} | mean_score={} | max_score={} | warning={}".format(log_row["orientation_signs"], log_row["orientation_score_mean_mm"], log_row["orientation_score_max_mm"], log_row["orientation_warning"]))

        # The source frame is taken from the imported dirty/original solid whenever possible.
        # This avoids moving only the treated surface while leaving the imported reference solid behind.
        transform_items = []
        if TRANSFORM_ALL_IMPORTED_BODIES_AS_RIGID_SET:
            transform_items = get_valid_transform_items(new_bodies)
        else:
            transform_items = [replacement_body]

        if DEBUG_LOG_TRANSFORM_DETAILS:
            debug_event("TRANSFORM_BEFORE", target_plan_id, target_body, target_sig, db_row, replacement_body, source_frame, "Before rigid transform", "transform_items={} | replacement_center_error_to_target={} mm".format(bodies_summary_for_debug(transform_items), center_error_between_body_and_target_frame(replacement_body, target_frame_for_alignment)))

        transform_result = align_items_to_target_frame(
            transform_items,
            source_frame,
            target_frame_for_alignment
        )

        if DEBUG_LOG_TRANSFORM_DETAILS:
            debug_event("TRANSFORM_AFTER", target_plan_id, target_body, target_sig, db_row, replacement_body, target_frame_for_alignment, "After rigid transform", "transform_result={} | transform_items={} | replacement_center_error_to_target={} mm".format(safe_str(transform_result), bodies_summary_for_debug(transform_items), center_error_between_body_and_target_frame(replacement_body, target_frame_for_alignment)))

        log_row["transformed_items_count"] = transform_result.get("items_transformed", "")
        log_row["transform_delta_x_mm"] = transform_result.get("delta_x_mm", "")
        log_row["transform_delta_y_mm"] = transform_result.get("delta_y_mm", "")
        log_row["transform_delta_z_mm"] = transform_result.get("delta_z_mm", "")
        log_row["transform_rotation_1_rad"] = transform_result.get("rotation_1_rad", "")
        log_row["transform_rotation_2_rad"] = transform_result.get("rotation_2_rad", "")

        post_center_error = center_error_between_body_and_target_frame(replacement_body, target_frame_for_alignment)
        try:
            if post_center_error != "" and POST_TRANSFORM_CENTER_WARNING_MM > 0.0:
                if float(post_center_error) > float(POST_TRANSFORM_CENTER_WARNING_MM):
                    debug_event(
                        "POST_TRANSFORM_CENTER_WARNING",
                        target_plan_id,
                        target_body,
                        target_sig,
                        db_row,
                        replacement_body,
                        target_frame_for_alignment,
                        "Replacement center differs from target frame after transform",
                        "center_error_mm={} | warning_limit_mm={}".format(post_center_error, POST_TRANSFORM_CENTER_WARNING_MM)
                    )
            if post_center_error != "" and POST_TRANSFORM_CENTER_ABORT_MM > 0.0:
                if float(post_center_error) > float(POST_TRANSFORM_CENTER_ABORT_MM):
                    raise Exception("Post-transform center error above abort limit: {} mm".format(post_center_error))
        except Exception as center_validation_error:
            # If abort limit was configured, the raise above should stop execution.
            if POST_TRANSFORM_CENTER_ABORT_MM > 0.0:
                raise
            debug_event("POST_TRANSFORM_CENTER_CHECK_FAILED", target_plan_id, target_body, target_sig, db_row, replacement_body, target_frame_for_alignment, "Center validation failed", safe_str(center_validation_error))

        final_replacement_body = replacement_body

        # Imported database items can behave as dependent components in SpaceClaim.
        # If we keep moving linked imported bodies, later replacements may drag earlier ones
        # and produce a pile at one target position. Copy/paste isolates each final surface.
        if BAKE_POSITIONED_REPLACEMENT_COPY:
            debug_event("BAKE_START", target_plan_id, target_body, target_sig, db_row, replacement_body, None, "Copying positioned replacement as independent body", body_summary_for_debug(replacement_body))

            baked_body, bake_error = copy_body_in_place_as_independent(replacement_body)

            if baked_body is not None:
                debug_event("BAKE_DONE", target_plan_id, target_body, target_sig, db_row, baked_body, None, "Independent baked copy created", "baked={} | error={}".format(body_summary_for_debug(baked_body), bake_error))
                final_replacement_body = baked_body
                log_row["baked_copy_created"] = 1
                log_row["baked_replacement_body_name"] = get_name(baked_body)
                log_row["imported_set_after_bake_action"] = safe_str(IMPORTED_SET_AFTER_BAKE_ACTION).upper()

                debug_event("CLEANUP_LINKED_IMPORT_START", target_plan_id, target_body, target_sig, db_row, None, None, "Cleaning linked imported set after bake", "action={} | bodies={}".format(IMPORTED_SET_AFTER_BAKE_ACTION, bodies_summary_for_debug(new_bodies)))
                cleanup_linked_imported_set_after_bake(new_bodies, db_row, target_sig)
                debug_event("CLEANUP_LINKED_IMPORT_DONE", target_plan_id, target_body, target_sig, db_row, None, None, "Linked imported set cleanup finished", "action={}".format(IMPORTED_SET_AFTER_BAKE_ACTION))

            else:
                debug_event("BAKE_FAILED", target_plan_id, target_body, target_sig, db_row, replacement_body, None, "Independent baked copy failed", bake_error)
                log_row["baked_copy_created"] = 0
                log_row["orientation_warning"] = safe_str(log_row.get("orientation_warning", "")) + " | bake independent copy failed: " + safe_str(bake_error)

                if not FALLBACK_TO_LINKED_REPLACEMENT_IF_BAKE_FAILS:
                    raise Exception("Could not bake independent replacement copy: " + safe_str(bake_error))

                # Fallback: keep the old V4 behavior.
                final_replacement_body = replacement_body
                cleanup_imported_non_replacement_bodies(new_bodies, replacement_body, db_row, target_sig)

        else:
            log_row["baked_copy_created"] = 0
            cleanup_imported_non_replacement_bodies(new_bodies, replacement_body, db_row, target_sig)

        if TAG_IMPORTED_REPLACEMENT_BODY:
            target_instance_label = make_target_instance_label(target_sig, target_plan_id)
            new_name = "DB_REPLACEMENT_{}_AT_{}".format(
                make_safe_name(safe_str(db_row.get("file_key", "DB"))),
                target_instance_label
            )
            set_name(final_replacement_body, new_name)

        log_row["replacement_body_name"] = get_name(final_replacement_body)
        if safe_str(log_row.get("baked_replacement_body_name")) == "" and log_row.get("baked_copy_created") == 1:
            log_row["baked_replacement_body_name"] = get_name(final_replacement_body)

        debug_event("FINAL_REPLACEMENT_READY", target_plan_id, target_body, target_sig, db_row, final_replacement_body, target_frame_for_alignment, "Final replacement body ready before target action", "final_center_error_to_target={} mm".format(center_error_between_body_and_target_frame(final_replacement_body, target_frame_for_alignment)))

        action = apply_original_after_replacement_action(target_body, db_row)
        log_row["target_action"] = action
        log_row["replaced"] = 1

        debug_event("TARGET_ACTION_DONE", target_plan_id, target_body, target_sig, db_row, final_replacement_body, None, "Original target action applied", "action={} | replacement={}".format(action, body_summary_for_debug(final_replacement_body)))

        delete_temporary_planes(temp_planes)
        append_log(log_row)
        debug_event("REPLACE_SUCCESS", target_plan_id, target_body, target_sig, db_row, final_replacement_body, None, "Replacement finished successfully", "")
        return True

    except Exception as e:
        err = safe_str(e)
        print("Replacement failed for target {}: {}".format(target_sig.get("body_name"), err))
        debug_event("REPLACE_FAILED", target_plan_id, target_body, target_sig, db_row, None, None, "Replacement failed", err)
        log_row["error_message"] = err
        append_log(log_row)
        delete_temporary_planes(temp_planes)
        return False

def summarize_plan_by_database_key(plan):
    counts = {}

    for item in plan:
        db_row = item.get("db_row")
        key = safe_str(db_row.get("file_key", ""))
        if key == "":
            key = safe_str(db_row.get("body_name", "UNKNOWN_DB"))

        counts[key] = counts.get(key, 0) + 1

    return counts

def print_plan_summary(plan):
