def to_spaceclaim_point_from_mm(p):
    return Point.Create(p[0] / 1000.0, p[1] / 1000.0, p[2] / 1000.0)

def to_spaceclaim_direction(v):
    return Direction.Create(v[0], v[1], v[2])

def create_datum_plane_from_axes(origin_mm, dir1_vec, dir2_vec, name):
    origin = to_spaceclaim_point_from_mm(origin_mm)
    dir1 = to_spaceclaim_direction(dir1_vec)
    dir2 = to_spaceclaim_direction(dir2_vec)
    frame = Frame.Create(origin, dir1, dir2)
    plane = Plane.Create(frame)
    result = DatumPlaneCreator.Create(plane, None)
    plane_created = list(result.GetCreated[DatumPlane]())[0]

    try:
        plane_created.SetName(name)
    except:
        try:
            plane_created.Name = name
        except:
            pass

    return plane_created

def create_temporary_target_planes(body, frame_data, index):
    if not CREATE_TARGET_REFERENCE_PLANES:
        return []

    body_name = make_safe_name(get_name(body))
    prefix = "TMP_MATCH_{:03d}_{}".format(index, body_name)
    planes = []

    try:
        planes.append(create_datum_plane_from_axes(frame_data["center"], frame_data["y"], frame_data["z"], prefix + "_YZ"))
        planes.append(create_datum_plane_from_axes(frame_data["center"], frame_data["x"], frame_data["z"], prefix + "_XZ"))
        planes.append(create_datum_plane_from_axes(frame_data["center"], frame_data["x"], frame_data["y"], prefix + "_XY"))
        print("Temporary target planes created for {}".format(get_name(body)))
    except Exception as e:
        print("Could not create temporary target planes for {}: {}".format(get_name(body), e))

    return planes

def delete_temporary_planes(planes):
    if not DELETE_TARGET_REFERENCE_PLANES_AFTER:
        return
    for p in planes:
        delete_item(p)

