def delete_item(item):
    if item is None:
        return False

    tested = []

    def try_delete(obj, label=""):
        try:
            if obj is None:
                return False

            Delete.Execute(Selection.Create(obj))

            print("Deleted {} {}".format(label, get_name(obj)))
            return True

        except Exception as e:
            tested.append("{} -> {}".format(label, e))
            return False

    # --------------------------------------------------------
    # 1) tenta deletar o próprio item
    # --------------------------------------------------------

    if try_delete(item, "item"):
        return True

    # --------------------------------------------------------
    # 2) tenta deletar parent/component
    # --------------------------------------------------------

    try:
        parent = item.Parent

        if try_delete(parent, "parent"):
            return True

    except:
        pass

    # --------------------------------------------------------
    # 3) tenta componente ancestral
    # --------------------------------------------------------

    try:
        comp = item.GetAncestor[Component]()

        if try_delete(comp, "ancestor_component"):
            return True

    except:
        pass

    # --------------------------------------------------------
    # 4) debug final
    # --------------------------------------------------------

    print(
        "Could not delete item {} | attempts={}".format(
            get_name(item),
            " || ".join(tested)
        )
    )

    return False

