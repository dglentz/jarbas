# ============================================================

def reduce_points_for_orientation(points):
    if points is None:
        return []

    count = len(points)
    if count <= VERTEX_CLOUD_MAX_POINTS:
        return points

    step = int(math.ceil(float(count) / float(VERTEX_CLOUD_MAX_POINTS)))
    if step < 1:
        step = 1

    reduced = []
    i = 0
    while i < count:
        reduced.append(points[i])
        i += step

    return reduced

def frame_with_target_signs(frame, sx_sign, sy_sign, sz_sign):
    return {
        "center": frame.get("center"),
        "x": vector_scale(frame.get("x"), sx_sign),
        "y": vector_scale(frame.get("y"), sy_sign),
        "z": vector_scale(frame.get("z"), sz_sign),
        "axis_quality": frame.get("axis_quality", ""),
        "warning": frame.get("warning", "")
    }

def clone_frame(frame):
    if frame is None:
        return None

    c = frame.get("center")
    x = frame.get("x")
    y = frame.get("y")
    z = frame.get("z")

    if c is None or x is None or y is None or z is None:
        return None

    return {
        "center": [c[0], c[1], c[2]],
        "x": [x[0], x[1], x[2]],
        "y": [y[0], y[1], y[2]],
        "z": [z[0], z[1], z[2]],
        "axis_quality": frame.get("axis_quality", ""),
        "warning": frame.get("warning", "")
    }

def local_coordinates_in_frame(point_mm, frame):
    c = frame.get("center")
    x = vector_normalize(frame.get("x"))
    y = vector_normalize(frame.get("y"))
    z = vector_normalize(frame.get("z"))

    if c is None or x is None or y is None or z is None:
        return None

    r = [point_mm[0] - c[0], point_mm[1] - c[1], point_mm[2] - c[2]]

    return [
        vector_dot(r, x),
        vector_dot(r, y),
        vector_dot(r, z)
    ]

def point_from_local_coordinates(local_xyz, frame):
    c = frame.get("center")
    x = vector_normalize(frame.get("x"))
    y = vector_normalize(frame.get("y"))
    z = vector_normalize(frame.get("z"))

    if c is None or x is None or y is None or z is None:
        return None

    p = [c[0], c[1], c[2]]
    p = vector_add(p, vector_scale(x, local_xyz[0]))
    p = vector_add(p, vector_scale(y, local_xyz[1]))
    p = vector_add(p, vector_scale(z, local_xyz[2]))

    return p

def distance_sq_mm(a, b):
    dx = a[0] - b[0]
    dy = a[1] - b[1]
    dz = a[2] - b[2]
    return dx * dx + dy * dy + dz * dz

def nearest_distance_sq_to_cloud(point_mm, target_points_mm):
    best = None

    for p in target_points_mm:
        d2 = distance_sq_mm(point_mm, p)
        if best is None or d2 < best:
            best = d2
    if best is None:
        return 999999999999.0

    return best

def vertex_cloud_orientation_score(source_points_mm, target_points_mm, source_frame, target_frame_candidate):
    """
    Scores how well the imported dirty solid vertex cloud maps onto the target dirty solid.

    Lower is better.
    This is used only to choose PCA axis signs, not to decide geometric matching.
    """
    if source_points_mm is None or target_points_mm is None:
        return 999999.0, 999999.0

    if len(source_points_mm) == 0 or len(target_points_mm) == 0:
        return 999999.0, 999999.0

    total = 0.0
    max_dist = 0.0
    count = 0

    for sp in source_points_mm:
        local = local_coordinates_in_frame(sp, source_frame)
        if local is None:
            continue

        mapped = point_from_local_coordinates(local, target_frame_candidate)
        if mapped is None:
            continue

        d2 = nearest_distance_sq_to_cloud(mapped, target_points_mm)
        d = math.sqrt(d2)

        total += d
        if d > max_dist:
            max_dist = d

        count += 1

    if count == 0:
        return 999999.0, 999999.0

    return total / float(count), max_dist


def frame_from_target_axis_variant(target_frame, permutation, signs):
    """
    Builds a target frame variant by reusing the same target center but changing
    the local axis order/signs. This is used only to resolve orientation
    ambiguity; it does not modify any reference plane in the database.
    """
    try:
        base = [
            vector_normalize(target_frame.get("x")),
            vector_normalize(target_frame.get("y")),
            vector_normalize(target_frame.get("z"))
        ]

        if base[0] is None or base[1] is None or base[2] is None:
            return None

        x = vector_scale(base[permutation[0]], signs[0])
        y = vector_scale(base[permutation[1]], signs[1])
        z = vector_scale(base[permutation[2]], signs[2])

        # Keep only right-handed frames. If z is opposite to x cross y, reject.
        z_check = vector_cross(x, y)
        z_check = vector_normalize(z_check)
        z = vector_normalize(z)

        if z_check is None or z is None:
            return None

        if vector_dot(z_check, z) < 0.999:
            return None

        return {
            "center": target_frame.get("center"),
            "x": x,
            "y": y,
            "z": z,
            "axis_quality": target_frame.get("axis_quality", ""),
            "warning": target_frame.get("warning", "")
        }
    except:
        return None

def generate_right_handed_target_frame_variants(target_frame):

    variants = []
    permutations = [
        (0, 1, 2),
        (0, 2, 1),
        (1, 0, 2),
        (1, 2, 0),
        (2, 0, 1),
        (2, 1, 0)
    ]

    sign_values = [-1.0, 1.0]

    for perm in permutations:
        for sx in sign_values:
            for sy in sign_values:
                for sz in sign_values:
                    signs = (sx, sy, sz)
                    frame = frame_from_target_axis_variant(target_frame, perm, signs)
                    if frame is None:
                        continue

                    label = "perm{}{}{}_sign{:+.0f}{:+.0f}{:+.0f}".format(
                        perm[0], perm[1], perm[2], sx, sy, sz
                    )
                    variants.append((label, frame))

    if len(variants) == 0:
        variants.append(("original_frame", target_frame))

    return variants

def choose_best_target_frame_variant_by_vertex_cloud(source_original_body, target_body, source_frame, target_frame):
    """
    Chooses the best target-frame orientation using source/target dirty-solid
    vertex clouds.

    improvement:
        - sign flips are not enough for asymmetric plates/brackets;
        - the local X/Y/Z order may also be ambiguous;
        - this function tests all right-handed permutations/signs of the target
          frame and selects the one with the lowest vertex-cloud distance.

    This does NOT modify the database template or its reference planes. It only
    changes the target frame used for transforming the copied replacement body.
    """
    result = {
        "frame": target_frame,
        "signs": "original_frame",
        "mean_score": "",
        "max_score": "",
        "warning": ""
    }

    if not USE_VERTEX_CLOUD_SIGN_RESOLUTION:
        return result

    if source_original_body is None or target_body is None:
        result["warning"] = "orientation resolution skipped: missing source or target original body"
        return result

    source_points = extract_unique_vertices_mm_from_body(source_original_body)
    target_points = extract_unique_vertices_mm_from_body(target_body)

    source_points = reduce_points_for_orientation(source_points)
    target_points = reduce_points_for_orientation(target_points)

    if len(source_points) == 0 or len(target_points) == 0:
        result["warning"] = "orientation resolution skipped: empty vertex cloud"
        return result

    if USE_VERTEX_CLOUD_AXIS_PERMUTATION_RESOLUTION:
        frame_candidates = generate_right_handed_target_frame_variants(target_frame)
    else:
        frame_candidates = [
            ("+X,+Y,+Z", frame_with_target_signs(target_frame, 1.0, 1.0, 1.0)),
            ("+X,-Y,-Z", frame_with_target_signs(target_frame, 1.0, -1.0, -1.0)),
            ("-X,+Y,-Z", frame_with_target_signs(target_frame, -1.0, 1.0, -1.0)),
            ("-X,-Y,+Z", frame_with_target_signs(target_frame, -1.0, -1.0, 1.0))
        ]

    best_frame = None
    best_label = ""
    best_mean = None
    best_max = None

    for label, candidate_frame in frame_candidates:
        if candidate_frame is None:
            continue

        mean_score, max_score = vertex_cloud_orientation_score(
            source_points,
            target_points,
            source_frame,
            candidate_frame
        )

        if best_mean is None or mean_score < best_mean:
            best_mean = mean_score
            best_max = max_score
            best_frame = candidate_frame
            best_label = label

    if best_frame is not None:
        result["frame"] = best_frame
        result["signs"] = best_label
        result["mean_score"] = best_mean
        result["max_score"] = best_max

        if best_mean is not None and best_mean > VERTEX_CLOUD_WARNING_SCORE_MM:
            result["warning"] = "high orientation vertex-cloud score"

    return result


