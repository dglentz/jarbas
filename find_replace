def get_body_aabb_mm(body):
    try:
        bbox = body.Shape.GetBoundingBox(Matrix.Identity)
        dx = abs(bbox.MaxCorner.X - bbox.MinCorner.X) * 1000.0
        dy = abs(bbox.MaxCorner.Y - bbox.MinCorner.Y) * 1000.0
        dz = abs(bbox.MaxCorner.Z - bbox.MinCorner.Z) * 1000.0
        dims = sorted([dx, dy, dz])
        return {
            "aabb_x_mm": dx,
            "aabb_y_mm": dy,
            "aabb_z_mm": dz,
            "aabb_min_mm": dims[0],
            "aabb_mid_mm": dims[1],
            "aabb_max_mm": dims[2],
            "aabb_ratio_max_min": safe_div(dims[2], dims[0]),
            "aabb_ratio_mid_min": safe_div(dims[1], dims[0])
        }
    except:
        return {
            "aabb_x_mm": None,
            "aabb_y_mm": None,
            "aabb_z_mm": None,
            "aabb_min_mm": None,
            "aabb_mid_mm": None,
            "aabb_max_mm": None,
            "aabb_ratio_max_min": None,
            "aabb_ratio_mid_min": None
        }

