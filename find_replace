def center_error_between_body_and_target_frame(body, target_frame):
    try:
        if body is None or target_frame is None:
            return ""
        cx, cy, cz = body_center_tuple_mm(body)
        tc = target_frame.get("center")
        if cx is None or cy is None or cz is None or tc is None:
            return ""
        dx = cx - tc[0]
        dy = cy - tc[1]
        dz = cz - tc[2]
        return math.sqrt(dx * dx + dy * dy + dz * dz)
    except:
        return ""

