def read_database_original_solids():
    global DATABASE_FILE_KEYS
    global DATABASE_BODY_NAMES
    rows = []
    DATABASE_FILE_KEYS = {}
    DATABASE_BODY_NAMES = {}

    if not os.path.exists(DATABASE_INDEX_CSV):
        print("database_index.csv not found:")
        print(DATABASE_INDEX_CSV)
        return rows

    with open(DATABASE_INDEX_CSV, "r") as f:
        reader = csv.DictReader(f, delimiter=";")
        for row in reader:
            role = safe_str(row.get("body_role_guess", ""))
            if role != DATABASE_ROLE_TO_MATCH:
                continue

            rows.append(row)

            file_key = safe_str(row.get("file_key", ""))
            body_name = safe_str(row.get("body_name", ""))

            if file_key != "":
                DATABASE_FILE_KEYS[file_key.upper()] = True
            if body_name != "":
                DATABASE_BODY_NAMES[body_name.upper()] = True

    print("DB original_solid rows loaded: {}".format(len(rows)))
    return rows

def resolve_database_item_file_path(db_row):
    file_key = safe_str(db_row.get("file_key", ""))
    csv_path = safe_str(db_row.get("file_path", ""))

    candidate_from_key = ""
    if file_key != "":
        candidate_from_key = os.path.join(DATABASE_ITEM_FOLDER, file_key + ".scdocx")

    if PREFER_FILE_KEY_AS_DATABASE_FILENAME:
        if candidate_from_key != "" and os.path.exists(candidate_from_key):
            return candidate_from_key, "file_key_filename"
        if csv_path != "" and os.path.exists(csv_path):
            return csv_path, "csv_file_path"
    else:
        if csv_path != "" and os.path.exists(csv_path):
            return csv_path, "csv_file_path"
        if candidate_from_key != "" and os.path.exists(candidate_from_key):
            return candidate_from_key, "file_key_filename"

    # Return the preferred path even if it does not exist, so the log is explicit.
    if candidate_from_key != "":
        return candidate_from_key, "missing_file_key_filename"
    return csv_path, "missing_csv_file_path"

