def make_safe_name(text):
    text = safe_str(text)
    if text == "":
        text = "BODY"

    out = []
    for ch in text:
        if ch.isalnum() or ch in ["_", "-"]:
            out.append(ch)
        else:
            out.append("_")
    return "".join(out)

