# MATCHING GATES AND SCORE
# ============================================================

def aabb_abs_errors(target, db):
    e_min = abs_err(target.get("aabb_min_mm"), db.get("aabb_min_mm"))
    e_mid = abs_err(target.get("aabb_mid_mm"), db.get("aabb_mid_mm"))
    e_max = abs_err(target.get("aabb_max_mm"), db.get("aabb_max_mm"))
    e_mean = (e_min + e_mid + e_max) / 3.0
    e_max_component = max(e_min, e_mid, e_max)
    return e_mean, e_max_component, e_min, e_mid, e_max

def aabb_rel_error(target, db):
    e1 = rel_err(target.get("aabb_min_mm"), db.get("aabb_min_mm"))
    e2 = rel_err(target.get("aabb_mid_mm"), db.get("aabb_mid_mm"))
    e3 = rel_err(target.get("aabb_max_mm"), db.get("aabb_max_mm"))
    return (e1 + e2 + e3) / 3.0

def volume_error(target, db):
    return rel_err(target.get("body_volume_mm3"), db.get("body_volume_mm3"))

def area_error(target, db):
    return rel_err(target.get("body_surface_area_mm2"), db.get("body_surface_area_mm2"))

def inertia_errors(target, db):
    t1 = safe_float(target.get("inertia_norm_1"))
    t2 = safe_float(target.get("inertia_norm_2"))
    t3 = safe_float(target.get("inertia_norm_3"))
    d1 = safe_float(db.get("inertia_norm_1"))
    d2 = safe_float(db.get("inertia_norm_2"))
    d3 = safe_float(db.get("inertia_norm_3"))

    if t1 is None or t2 is None or t3 is None:
        return 999.0, 999.0, 999.0, 999.0, 999.0
    if d1 is None or d2 is None or d3 is None:
        return 999.0, 999.0, 999.0, 999.0, 999.0

    e1 = abs(t1 - d1)
    e2 = abs(t2 - d2)
    e3 = abs(t3 - d3)
    return (e1 + e2 + e3) / 3.0, max(e1, e2, e3), e1, e2, e3

def topology_errors(target, db):
    e_faces = rel_err(target.get("num_faces"), db.get("num_faces"))
    e_edges = rel_err(target.get("num_edges"), db.get("num_edges"))
    e_planar = rel_err(target.get("num_planar_faces"), db.get("num_planar_faces"))
    e_cyl = rel_err(target.get("num_cylindrical_faces"), db.get("num_cylindrical_faces"))
    return e_faces, e_edges, e_planar, e_cyl

def is_slender_aabb_signature(sig):
    ratio = safe_float(sig.get("aabb_ratio_max_min"), None)
    if ratio is None:
        amin = safe_float(sig.get("aabb_min_mm"), None)
        amax = safe_float(sig.get("aabb_max_mm"), None)
        if amin is None or amax is None or abs(amin) < 1e-9:
            return False
        ratio = amax / amin
    return ratio >= 20.0

def passes_aabb_gate(target, db):
    e_abs_mean, e_abs_max, e_abs_min, e_abs_mid, e_abs_long = aabb_abs_errors(target, db)

    t_min = safe_float(target.get("aabb_min_mm"), None)
    t_mid = safe_float(target.get("aabb_mid_mm"), None)
    t_max = safe_float(target.get("aabb_max_mm"), None)

    d_min = safe_float(db.get("aabb_min_mm"), None)
    d_mid = safe_float(db.get("aabb_mid_mm"), None)
    d_max = safe_float(db.get("aabb_max_mm"), None)

    if t_min is None or t_mid is None or t_max is None:
        return False
    if d_min is None or d_mid is None or d_max is None:
        return False

    if is_slender_aabb_signature(target) and is_slender_aabb_signature(db):
        e_mid_rel = rel_err(t_mid, d_mid)
        e_max_rel = rel_err(t_max, d_max)
        e_mid_abs = abs(t_mid - d_mid)
        e_max_abs = abs(t_max - d_max)

        if e_mid_abs > 5.0 * SAFETY_FACTOR:
            return False
        if e_max_abs > 5.0 * SAFETY_FACTOR:
            return False
        if e_mid_rel > 0.030 * SAFETY_FACTOR:
            return False
        if e_max_rel > 0.010 * SAFETY_FACTOR:
            return False
        return True

    e_rel = aabb_rel_error(target, db)

    if e_abs_max > AABB_ABS_TOL_MM * SAFETY_FACTOR:
        return False
    if e_rel > AABB_REL_TOL * SAFETY_FACTOR:
        return False

    return True

def topology_integer_signature_matches(target, db):
    """
    Checks the stable topological counters exactly. This is deliberately stricter
    than the normal topology gate because it is used only to bypass AABB failures.
    """
    fields = [
        "num_faces",
        "num_edges",
        "num_planar_faces",
        "num_cylindrical_faces",
        "num_conical_faces",
        "num_toroidal_faces"
    ]

    for field in fields:
        t = safe_int(target.get(field), None)
        d = safe_int(db.get(field), None)
        if t is None or d is None:
            return False
        if t != d:
            return False
    return True

def passes_mass_topology_aabb_fallback(target, db, metrics=None):
    """
    This does NOT loosen the whole matcher. It only bypasses AABB when:
      - volume and area are practically identical;
      - face/edge/type counters are exactly identical;
      - inertia from AABB is still reasonably close;
      - AABB is not wildly different.

    Intended case from diagnostic:
      DB folded_plate_6: 48.011 x 90.009 x 90.009
      target Filete10:  51.114 x 90.009 x 91.625
      volume/area/faces/edges identical, but strict AABB failed.
    """
    if not ALLOW_AABB_FAIL_WHEN_MASS_TOPOLOGY_MATCH:
        return False

    if metrics is None:
        metrics = final_match_score(target, db)

    e_abs_max = safe_float(metrics.get("e_aabb_abs_max"), 999999.0)
    e_aabb_rel = safe_float(metrics.get("e_aabb_rel"), 999999.0)
    e_vol = safe_float(metrics.get("e_volume"), 999999.0)
    e_area = safe_float(metrics.get("e_area"), 999999.0)
    e_inertia_mean = safe_float(metrics.get("e_inertia_mean"), 999999.0)
    e_inertia_max = safe_float(metrics.get("e_inertia_max"), 999999.0)
    score = safe_float(metrics.get("score"), 999999.0)

    if e_abs_max > MASS_TOPOLOGY_AABB_ABS_TOL_MM * SAFETY_FACTOR:
        return False
    if e_aabb_rel > MASS_TOPOLOGY_AABB_REL_TOL * SAFETY_FACTOR:
        return False
    if e_vol > MASS_TOPOLOGY_VOLUME_REL_TOL * SAFETY_FACTOR:
        return False
    if e_area > MASS_TOPOLOGY_AREA_REL_TOL * SAFETY_FACTOR:
        return False
    if not topology_integer_signature_matches(target, db):
        return False
    if e_inertia_mean > MASS_TOPOLOGY_INERTIA_MEAN_TOL * SAFETY_FACTOR:
        return False
    if e_inertia_max > MASS_TOPOLOGY_INERTIA_MAX_TOL * SAFETY_FACTOR:
        return False
    if score > MASS_TOPOLOGY_SCORE_MAX * SAFETY_FACTOR:
        return False
    return True

def passes_volume_gate(target, db):
    return volume_error(target, db) <= VOLUME_REL_TOL * SAFETY_FACTOR

def passes_area_gate(target, db):
    return area_error(target, db) <= AREA_REL_TOL * SAFETY_FACTOR

def passes_inertia_gate(target, db):
    e_mean, e_max, e1, e2, e3 = inertia_errors(target, db)
    if e_mean > INERTIA_MEAN_ABS_TOL * SAFETY_FACTOR:
        return False
    if e_max > INERTIA_MAX_ABS_TOL * SAFETY_FACTOR:
        return False
    return True

def passes_topology_gate(target, db):
    if not STRICT_TOPOLOGY:
        return True
    e_faces, e_edges, e_planar, e_cyl = topology_errors(target, db)
    if e_faces > FACE_COUNT_REL_TOL * SAFETY_FACTOR:
        return False
    if e_edges > EDGE_COUNT_REL_TOL * SAFETY_FACTOR:
        return False
    if e_planar > PLANAR_COUNT_REL_TOL * SAFETY_FACTOR:
        return False
    if e_cyl > CYL_COUNT_REL_TOL * SAFETY_FACTOR:
        return False
    return True

def final_match_score(target, db):
    e_abs_mean, e_abs_max, e_abs_min, e_abs_mid, e_abs_long = aabb_abs_errors(target, db)
    e_aabb_rel = aabb_rel_error(target, db)
    e_vol = volume_error(target, db)
    e_area = area_error(target, db)
    e_inertia_mean, e_inertia_max, e_i1, e_i2, e_i3 = inertia_errors(target, db)
    e_faces, e_edges, e_planar, e_cyl = topology_errors(target, db)
    e_topology = (e_faces + e_edges + e_planar + e_cyl) / 4.0

    score = (
        0.45 * e_aabb_rel +
        0.20 * e_inertia_mean +
        0.20 * e_area +
        0.10 * e_vol +
        0.05 * e_topology
    )

    return {
        "score": score,
        "e_aabb_abs_mean": e_abs_mean,
        "e_aabb_abs_max": e_abs_max,
        "e_aabb_abs_min": e_abs_min,
        "e_aabb_abs_mid": e_abs_mid,
        "e_aabb_abs_long": e_abs_long,
        "e_aabb_rel": e_aabb_rel,
        "e_volume": e_vol,
        "e_area": e_area,
        "e_inertia_mean": e_inertia_mean,
        "e_inertia_max": e_inertia_max,
        "e_topology": e_topology,
        "e_faces": e_faces,
        "e_edges": e_edges,
        "e_planar": e_planar,
        "e_cyl": e_cyl
    }

def passes_volume_prefilter(target, db):
    if not ENABLE_VOLUME_PREFILTER:
        return True

    t_vol = safe_float(target.get("body_volume_mm3"), None)
    d_vol = safe_float(db.get("body_volume_mm3"), None)
    if t_vol is None or d_vol is None:
        return True
    if abs(t_vol) < 1e-9 or abs(d_vol) < 1e-9:
        return True
    return rel_err(t_vol, d_vol) <= VOLUME_PREFILTER_REL_TOL

def find_best_database_match_precise(target_sig, db_rows):
    best = None
    best_metrics = None
    best_score = None
    count_total = 0
    count_pass_aabb = 0
    count_pass_aabb_relaxed = 0
    count_pass_volume = 0
    count_pass_area = 0
    count_pass_inertia = 0
    count_pass_topology = 0
    count_pass_final = 0

    for db in db_rows:
        count_total += 1

        if not passes_volume_prefilter(target_sig, db):
            continue

        metrics = final_match_score(target_sig, db)
        score = metrics.get("score")

        aabb_strict_ok = passes_aabb_gate(target_sig, db)
        aabb_relaxed_ok = False

        if not aabb_strict_ok:
            aabb_relaxed_ok = passes_mass_topology_aabb_fallback(target_sig, db, metrics)

        if not aabb_strict_ok and not aabb_relaxed_ok:
            continue

        count_pass_aabb += 1
        if aabb_relaxed_ok and not aabb_strict_ok:
            count_pass_aabb_relaxed += 1
            try:
                metrics["match_mode"] = "AABB_RELAXED_BY_MASS_TOPOLOGY"
            except:
                pass

        if not passes_volume_gate(target_sig, db):
            continue
        count_pass_volume += 1

        if not passes_area_gate(target_sig, db):
            continue
        count_pass_area += 1

        if not passes_inertia_gate(target_sig, db):
            # its wider industrial limit, do not reject here using the legacy
            # strict AABB-inertia threshold.
            if not aabb_relaxed_ok:
                continue
        count_pass_inertia += 1

        if not passes_topology_gate(target_sig, db):
            continue
        count_pass_topology += 1

        # For the strict path, keep the legacy score rule.
        # For the relaxed path, passes_mass_topology_aabb_fallback has already
        # checked MASS_TOPOLOGY_SCORE_MAX.
        if aabb_strict_ok:
            score_ok = score <= MAX_ACCEPT_SCORE * SAFETY_FACTOR
        else:
            score_ok = score <= MASS_TOPOLOGY_SCORE_MAX * SAFETY_FACTOR

        if score_ok:
            count_pass_final += 1
            if best_score is None or score < best_score:
                best_score = score
                best = db
                best_metrics = metrics

    counters = {
        "count_total_db": count_total,
        "count_pass_aabb": count_pass_aabb,
        "count_pass_aabb_relaxed": count_pass_aabb_relaxed,
        "count_pass_volume": count_pass_volume,
        "count_pass_area": count_pass_area,
        "count_pass_inertia": count_pass_inertia,
        "count_pass_topology": count_pass_topology,
        "count_pass_final": count_pass_final
    }
    return best, best_score, best_metrics, counters

