    print("")
    print("Replacement plan summary:")
    print("Accepted targets planned: {}".format(len(plan)))

    for key in counts:
        print("  {} -> {} target(s)".format(key, counts.get(key)))

def existing_replacement_for_target_signature(target_sig, db_row):
    """
    When original targets are kept, running the macro twice would otherwise add
    duplicate DB_REPLACEMENT surfaces. The final replacement name contains the
    database key and the original target center token, so this check can skip
    targets that were already treated in a previous run.
    """
    if not SKIP_TARGETS_WITH_EXISTING_REPLACEMENT_AT_SAME_CENTER:
        return False

    try:
        db_key = make_safe_name(safe_str(db_row.get("file_key", "DB")))
        cx = format_float3(target_sig.get("center_x_mm", ""))
        cy = format_float3(target_sig.get("center_y_mm", ""))
        cz = format_float3(target_sig.get("center_z_mm", ""))
        center_token = "C{}_{}_{}".format(cx, cy, cz)
        wanted_prefix = (FINAL_REPLACEMENT_PREFIX + db_key + "_AT_").upper()

        for b in get_all_bodies():
            try:
                n = safe_str(get_name(b))
                nu = n.upper()
                if nu.startswith(wanted_prefix) and center_token in n:
                    return True
            except:
                pass
    except:
        return False
    return False


def build_replacement_plan_from_initial_snapshot(bodies, db_rows):
    plan = []

    processed = 0
    accepted_count = 0
    rejected_count = 0
    skipped_count = 0

    print("")
    print("Building replacement plan from initial assembly snapshot...")

    for body in bodies:
        if PROCESS_ONLY_FIRST_N > 0 and processed >= PROCESS_ONLY_FIRST_N:
            break

        body_name = get_name(body)

        if should_skip_target_body(body, body_name):
            skipped_count += 1
            continue

        if ONLY_VISIBLE_BODIES and not is_visible(body):
            skipped_count += 1
            continue

        target_sig = build_body_signature(body)

        if target_sig.get("body_role_guess") != "original_solid":
            skipped_count += 1
            continue

        if target_sig.get("aabb_max_mm") is None:
            skipped_count += 1
            continue

        if safe_float(target_sig.get("aabb_max_mm"), 0.0) < MIN_AABB_MAX_MM:
            skipped_count += 1
            continue

        best, score, metrics, counters = find_best_database_match_precise(target_sig, db_rows)
        processed += 1

        if DEBUG_VERBOSE_CONSOLE:
            print("[PLAN DEBUG] candidate={} body={} role={} aabb=({}, {}, {}) faces={} edges={}".format(
                processed,
                target_sig.get("body_name"),
                target_sig.get("body_role_guess"),
                format_float3(target_sig.get("aabb_min_mm")),
                format_float3(target_sig.get("aabb_mid_mm")),
                format_float3(target_sig.get("aabb_max_mm")),
                target_sig.get("num_faces"),
                target_sig.get("num_edges")
            ))

        if best is None or score is None:
            rejected_count += 1
            if DEBUG_LOG_REJECTED_CANDIDATES:
                append_plan_diagnostic(make_plan_diagnostic_row(processed, "", "REJECTED_NO_MATCH", "No database row passed all gates", target_sig, {}, "", {}, counters))
            continue

        if existing_replacement_for_target_signature(target_sig, best):
            skipped_count += 1
            append_full_txt_log(
                "PLAN_SKIPPED_EXISTING_REPLACEMENT",
                "target={} | db_key={} | center=({}, {}, {})".format(
                    target_sig.get("body_name"),
                    safe_str(best.get("file_key", "DB")),
                    format_float3(target_sig.get("center_x_mm", "")),
                    format_float3(target_sig.get("center_y_mm", "")),
                    format_float3(target_sig.get("center_z_mm", ""))
                )
            )
            continue

        target_frame_snapshot = None
        target_vertex_cloud_snapshot = []

        if STORE_TARGET_FRAME_IN_PLAN:
            target_frame_snapshot = compute_ordered_reference_frame_from_body(body)
            if target_frame_snapshot is None:
                rejected_count += 1
                print("Rejected planned match because target frame could not be computed: {}".format(target_sig.get("body_name")))
                append_plan_diagnostic(make_plan_diagnostic_row(processed, "", "REJECTED_FRAME_FAILED", "Target frame could not be computed", target_sig, best, score, metrics, counters))
                continue

        if STORE_TARGET_VERTEX_CLOUD_IN_PLAN:
            target_vertex_cloud_snapshot = reduce_points_for_orientation(extract_unique_vertices_mm_from_body(body))

        accepted_count += 1

        # Color is applied during planning, before any import/replacement changes the model tree.
        color_body_as_match(body)

        plan_id = "PLAN_{:04d}".format(len(plan) + 1)

        plan.append({
            "plan_id": plan_id,
            "body": body,
            "target_sig": target_sig,
            "target_frame": target_frame_snapshot,
            "target_vertex_cloud": target_vertex_cloud_snapshot,
            "db_row": best,
            "score": score
        })

        append_plan_diagnostic(make_plan_diagnostic_row(processed, plan_id, "ACCEPTED", "Planned for replacement", target_sig, best, score, metrics, counters))

        debug_event("PLAN_ACCEPTED", plan_id, body, target_sig, best, body, target_frame_snapshot, "Target planned for replacement", "score={} | metrics={} | counters={}".format(score, safe_str(metrics), safe_str(counters)))

        print("")
        print("MATCH PLANNED")
        print("Target: {}".format(target_sig.get("body_name")))
        print("DB    : {}".format(best.get("body_name")))
        print("Key   : {}".format(best.get("file_key")))
        print("Score : {}".format(score))
        if target_frame_snapshot is not None:
            c = target_frame_snapshot.get("center")
            if c is not None:
                print("Target center mm: {}, {}, {}".format(c[0], c[1], c[2]))

    return plan, processed, accepted_count, rejected_count, skipped_count

