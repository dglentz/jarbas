        append_full_txt_log("TEMPLATE_CLEANUP_DISABLED", safe_str(summary))
        return summary

    action = safe_str(TEMPLATE_CLEANUP_ACTION_AFTER_WORKFLOW).upper()
    if action == "":
        action = "DELETE"
    summary["action"] = action

    if action == "KEEP":
        append_full_txt_log("TEMPLATE_CLEANUP_KEEP", "Templates intentionally kept")
        return summary

    template_bodies = []
    template_body_keys = {}
    template_body_tokens = {}
    template_components = []
    template_component_keys = {}

    try:
        for key in template_cache:
            info = template_cache.get(key)
            if info is None:
                continue

            append_full_txt_log("TEMPLATE_CACHE_ITEM", "key={} | bodies={} | components={}".format(
                key,
                bodies_summary_for_debug(info.get("template_bodies", [])),
                objects_summary_for_debug(info.get("template_components", []))
            ))

            for b in info.get("template_bodies", []):
                add_body_unique_by_identity(b, template_bodies, template_body_keys)

            for c in info.get("template_components", []):
                add_unique_object(c, template_components, template_component_keys)

            for b in info.get("template_bodies", []):
                for c in get_template_body_parent_candidates(b):
                    add_unique_object(c, template_components, template_component_keys)
    except Exception as e:
        append_full_txt_log_exception("TEMPLATE_CLEANUP_COLLECT_ERROR", e)

    template_body_tokens = make_body_snapshot_token_dict_from_bodies(template_bodies)

    summary["template_bodies"] = len(template_bodies)
    summary["template_components"] = len(template_components)

    if len(template_bodies) == 0:
        print("Template cleanup: no template bodies found in cache.")
        append_full_txt_log("TEMPLATE_CLEANUP_NO_BODIES", "No bodies in template cache")
        return summary

    print("")
    print("Cleaning  database templates after replacement loop...")
    print("Template cleanup action: {}".format(action))
    print("Template bodies found: {}".format(len(template_bodies)))
    print("Template component/container candidates: {}".format(len(template_components)))

    append_full_txt_log("TEMPLATE_CLEANUP_COLLECTED", "bodies={} | components={}".format(
        len(template_bodies),
        len(template_components)
    ))

    if action == "HIDE":
        for b in template_bodies:
            if hide_item(b):
                summary["body_hidden"] += 1
                append_full_txt_log("TEMPLATE_HIDE_OK", body_summary_for_debug(b))
            else:
                summary["failed"] += 1
                append_full_txt_log("TEMPLATE_HIDE_FAILED", body_summary_for_debug(b))
        append_full_txt_log("TEMPLATE_CLEANUP_SUMMARY", safe_str(summary))
        return summary

    if action != "DELETE":
        append_full_txt_log("TEMPLATE_CLEANUP_UNSUPPORTED_ACTION", action)
        print("Template cleanup skipped: unsupported action '{}'".format(action))
        return summary

    handled_body_keys = {}

    # 1) Prefer deleting component/container occurrences, not linked bodies.
    if DELETE_TEMPLATE_COMPONENTS_WHEN_SAFE:
        for c in template_components:
            try:
                safe, reason, comp_bodies = component_is_safe_template_container(c, template_body_keys, template_body_tokens)
                append_full_txt_log(
                    "TEMPLATE_COMPONENT_EVAL",
                    "candidate={} | safe={} | reason={} | bodies={}".format(
                        object_summary_for_debug(c),
                        safe,
                        reason,
                        bodies_summary_for_debug(comp_bodies)
                    )
                )

                if not safe:
                    continue

                summary["safe_component_candidates"] += 1
                ok, err = try_direct_delete_object(c, "template_component")
                if ok:
                    summary["component_deleted"] += 1
                    for b in comp_bodies:
                        bkey = object_identity_key(b)
                        if bkey != "":
                            handled_body_keys[bkey] = True
                else:
                    summary["failed"] += 1
            except Exception as e:
                summary["failed"] += 1
                append_full_txt_log_exception("TEMPLATE_COMPONENT_DELETE_LOOP_ERROR", e)

    # 2) Remaining linked template bodies: do not delete directly unless explicitly enabled.
    for b in template_bodies:
        bkey = object_identity_key(b)
        if bkey != "" and bkey in handled_body_keys:
            continue

        if TEMPLATE_DELETE_DIRECT_BODY_FALLBACK:
            ok, err = try_direct_delete_object(b, "template_body_direct_fallback")
            if ok:
                summary["body_deleted"] += 1
                continue
            else:
                summary["failed"] += 1

        else:
            summary["direct_body_delete_skipped"] += 1
            append_full_txt_log(
                "TEMPLATE_DIRECT_BODY_DELETE_SKIPPED",
                "Direct body delete disabled to avoid SpaceClaim save prompt | body={}".format(body_summary_for_debug(b))
            )

        if TEMPLATE_HIDE_IF_DELETE_FAILS:
            if hide_item(b):
                summary["body_hidden"] += 1
                append_full_txt_log("TEMPLATE_BODY_HIDE_FALLBACK_OK", body_summary_for_debug(b))
            else:
                summary["failed"] += 1
                append_full_txt_log("TEMPLATE_BODY_HIDE_FALLBACK_FAILED", body_summary_for_debug(b))
        else:
            append_full_txt_log("TEMPLATE_BODY_LEFT_VISIBLE_AFTER_DELETE_SKIP", body_summary_for_debug(b))

    print(
        "Template cleanup finished: action={} | template_bodies={} | template_components={} | safe_components={} | component_deleted={} | body_deleted={} | body_hidden={} | direct_body_delete_skipped={} | failed={}".format(
            summary["action"],
            summary["template_bodies"],
            summary["template_components"],
            summary["safe_component_candidates"],
            summary["component_deleted"],
            summary["body_deleted"],
            summary["body_hidden"],
            summary["direct_body_delete_skipped"],
            summary["failed"]
        )
    )

    append_full_txt_log("TEMPLATE_CLEANUP_SUMMARY", safe_str(summary))
    return summary


def prepare_database_template_for_row(db_row, template_cache):

    key = db_template_key(db_row)

    if key in template_cache:
        return template_cache[key]

    db_file_path, path_source = resolve_database_item_file_path(db_row)
    debug_event(
        "TEMPLATE_IMPORT_START",
        "TEMPLATE_" + key,
        None,
        {},
        db_row,
        None,
        None,
        "Importing database item as V10 template",
        "db_file_path={} | source={}".format(db_file_path, path_source)
    )

    import_file_path = db_file_path
    import_path_source = path_source

    # Use a unique temp file only once for the template import, to avoid any
    # accidental file/path cache during import.
    if USE_UNIQUE_TEMP_IMPORT_COPY_PER_PLAN:
        import_file_path, import_path_source = make_unique_temp_import_file(
            db_file_path,
            db_row,
            "TEMPLATE_" + key
        )

    new_bodies, import_method = insert_database_file_into_current_document(import_file_path)
    template_components = list(LAST_INSERT_CREATED_COMPONENTS)
    cleanup_unique_temp_import_file(import_file_path, db_file_path)

    if len(new_bodies) == 0:
        raise Exception("V10 template import produced no bodies for database item: " + key)

    replacement_body = choose_imported_treated_surface_body(new_bodies, db_row)
    original_body = choose_imported_original_body(new_bodies, db_row)

    if replacement_body is None:
        raise Exception("V10 template import could not identify treated/replacement body for: " + key)

    source_frame = None
    source_frame_source = ""

    if USE_DATABASE_ROW_FRAME_AS_SOURCE_FIRST:
        source_frame = frame_from_database_row(db_row)
        if source_frame is not None:
            source_frame_source = "database_row_plane_frame"

    if source_frame is None and original_body is not None:
        source_frame = compute_ordered_reference_frame_from_body(original_body)
        if source_frame is not None:
            source_frame_source = "template_original_body_fallback"

    if source_frame is None:
        source_frame = compute_ordered_reference_frame_from_body(replacement_body)
        if source_frame is not None:
            source_frame_source = "template_replacement_body_fallback"

    if source_frame is None:
        raise Exception("V10 template source frame could not be created for: " + key)

    template_info = {
        "key": key,
        "db_row": db_row,
        "db_file_path": db_file_path,
        "db_item_file_path_source": path_source,
        "import_method": import_method,
        "template_import_file_path": import_file_path,
        "template_import_path_source": import_path_source,
        "template_components": template_components,
        "template_component_detail": LAST_INSERT_COMPONENT_DETAIL,
        "template_bodies": list(new_bodies),
        "template_replacement_body": replacement_body,
        "template_original_body": original_body,
        "source_frame": source_frame,
        "source_frame_source": source_frame_source
    }

    debug_event(
        "TEMPLATE_IMPORT_DONE",
        "TEMPLATE_" + key,
        None,
        {},
        db_row,
        replacement_body,
        source_frame,
        "Database item template ready",
        "method={} | bodies={} | components={} | component_detail={} | replacement={} | original={} | source_frame_source={} | import_file={}".format(
            import_method,
            len(new_bodies),
            len(template_components),
            LAST_INSERT_COMPONENT_DETAIL,
            body_summary_for_debug(replacement_body),
            body_summary_for_debug(original_body),
            source_frame_source,
            import_file_path
        )
    )

    # Keep the template untouched. Hiding is okay because future copy/paste uses
    # the object reference, but it is not transformed.
    apply_template_body_action(new_bodies, key)

    template_cache[key] = template_info
    return template_info

def copy_template_replacement_body(template_info, target_plan_id):
    template_body = template_info.get("template_replacement_body")

    if template_body is None:
        return None, "template replacement body is None"

    copied_body, copy_error = copy_body_in_place_as_independent(template_body)

    if copied_body is None:
        return None, copy_error

    try:
        set_name(copied_body, "{}_COPY_{}_{}".format(FINAL_REPLACEMENT_PREFIX, template_info.get("key", "DB"), target_plan_id))
    except:
        pass

    return copied_body, ""

def replace_one_target_body_from_template(target_body, target_sig, db_row, score, match_index, target_frame_snapshot, target_plan_id, template_cache, target_vertex_cloud_snapshot=None):

    temp_planes = []

    db_file_path, path_source = resolve_database_item_file_path(db_row)

    log_row = {
        "datetime": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "target_body_name": target_sig.get("body_name"),
        "target_action": "",
        "accepted": 1,
        "replaced": 0,
        "score": score,
        "db_file_key": db_row.get("file_key", ""),
        "db_body_name": db_row.get("body_name", ""),
        "db_pair_id": db_row.get("pair_id", ""),
        "db_item_file_path": db_file_path,
        "db_item_file_path_source": path_source,
        "replacement_body_name": "",
        "import_method": "V10_TEMPLATE_COPY",
        "new_bodies_count": "",
        "transformed_items_count": "",
        "transform_delta_x_mm": "",
        "transform_delta_y_mm": "",
        "transform_delta_z_mm": "",
        "transform_rotation_1_rad": "",
        "transform_rotation_2_rad": "",
        "target_plan_id": target_plan_id,
        "target_center_x_mm": "",
        "target_center_y_mm": "",
        "target_center_z_mm": "",
        "source_frame_source": "",
        "source_original_body_name": "",
        "target_axis_quality": "",
        "target_ref_warning": "",
        "orientation_signs": "",
        "orientation_score_mean_mm": "",
        "orientation_score_max_mm": "",
        "orientation_warning": "",
        "baked_copy_created": 1,
        "baked_replacement_body_name": "",
        "imported_set_after_bake_action": "TEMPLATE_REUSED_NOT_MOVED",
        "individual_instance_mode": "V10_TEMPLATE_COPY_PER_OCCURRENCE",
        "error_message": ""
    }

    try:
        target_frame = clone_frame(target_frame_snapshot)

        if target_frame is None:
            # Last resort only. Normal V10 must use the frozen planned frame.
            target_frame = compute_ordered_reference_frame_from_body(target_body)

        if target_frame is None:
            raise Exception("V10 could not obtain target frame for plan " + safe_str(target_plan_id))

        c = target_frame.get("center")
        if c is not None:
            log_row["target_center_x_mm"] = c[0]
            log_row["target_center_y_mm"] = c[1]
            log_row["target_center_z_mm"] = c[2]

        log_row["target_axis_quality"] = target_frame.get("axis_quality", "")
        log_row["target_ref_warning"] = target_frame.get("warning", "")

        debug_event(
            "V10_REPLACE_START",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            target_body,
            target_frame,
            "Starting V10 template-copy replacement",
            "target={} | db_key={} | score={}".format(
                body_summary_for_debug(target_body),
                db_template_key(db_row),
                score
            )
        )

        temp_planes = create_temporary_target_planes(target_body, target_frame, match_index)

        if DRY_RUN:
            log_row["target_action"] = "DRY_RUN"
            append_log(log_row)
            delete_temporary_planes(temp_planes)
            return True

        template_info = prepare_database_template_for_row(db_row, template_cache)
        source_frame = clone_frame(template_info.get("source_frame"))

        if source_frame is None:
            raise Exception("V10 template has no source frame for db key " + db_template_key(db_row))

        log_row["source_frame_source"] = template_info.get("source_frame_source", "")
        try:
            original_body = template_info.get("template_original_body")
            log_row["source_original_body_name"] = get_name(original_body)
        except:
            pass

        replacement_copy, copy_error = copy_template_replacement_body(template_info, target_plan_id)

        if replacement_copy is None:
            debug_event(
                "V10_TEMPLATE_COPY_FAILED",
                target_plan_id,
                target_body,
                target_sig,
                db_row,
                template_info.get("template_replacement_body"),
                source_frame,
                "Could not copy template replacement body",
                copy_error
            )
            if ABORT_IF_TEMPLATE_COPY_FAILS:
                raise Exception("V10 template replacement copy failed: " + safe_str(copy_error))
            return False

        debug_event(
            "_COPY_READY",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            source_frame,
            "Template copy created and ready for transform",
            body_summary_for_debug(replacement_copy)
        )

        target_frame_for_alignment = target_frame

        # Optional only. Default False because repeated target bodies may share master references.
        if USE_VERTEX_CLOUD_ORIENTATION_IN_TEMPLATE_WORKFLOW:
            orientation_source = "live_target_body"

            if (
                USE_PLANNED_TARGET_VERTEX_CLOUD_FOR_ORIENTATION and
                target_vertex_cloud_snapshot is not None and
                len(target_vertex_cloud_snapshot) > 0
            ):
                orientation_result = choose_best_target_frame_variant_by_planned_target_points(
                    template_info.get("template_original_body"),
                    target_vertex_cloud_snapshot,
                    source_frame,
                    target_frame
                )
                orientation_source = "planned_target_vertex_cloud"
            else:
                orientation_result = choose_best_target_frame_variant_by_vertex_cloud(
                    template_info.get("template_original_body"),
                    target_body,
                    source_frame,
                    target_frame
                )

            target_frame_for_alignment = orientation_result.get("frame", target_frame)
            log_row["orientation_signs"] = orientation_result.get("signs", "")
            log_row["orientation_score_mean_mm"] = orientation_result.get("mean_score", "")
            log_row["orientation_score_max_mm"] = orientation_result.get("max_score", "")
            log_row["orientation_warning"] = orientation_result.get("warning", "")

            append_full_txt_log(
                "V16_ORIENTATION_SOURCE",
                "plan={} | target={} | db_key={} | source={} | target_vertices={} | signs={} | mean_score={} | max_score={} | warning={}".format(
                    target_plan_id,
                    target_sig.get("body_name"),
                    safe_str(db_row.get("file_key", "DB")),
                    orientation_source,
                    len(target_vertex_cloud_snapshot) if target_vertex_cloud_snapshot is not None else 0,
                    log_row["orientation_signs"],
                    log_row["orientation_score_mean_mm"],
                    log_row["orientation_score_max_mm"],
                    log_row["orientation_warning"]
                )
            )
        else:
            log_row["orientation_signs"] = "frame_as_planned_no_vertex_cloud"

        debug_event(
            "TRANSFORM_BEFORE",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            source_frame,
            "Before V10 transform of copied replacement only",
            "source_frame={} | target_frame={}".format(frame_summary_for_debug(source_frame), frame_summary_for_debug(target_frame_for_alignment))
        )

        transform_result = align_items_to_target_frame(
            [replacement_copy],
            source_frame,
            target_frame_for_alignment
        )

        log_row["transformed_items_count"] = transform_result.get("items_transformed", "")
        log_row["transform_delta_x_mm"] = transform_result.get("delta_x_mm", "")
        log_row["transform_delta_y_mm"] = transform_result.get("delta_y_mm", "")
        log_row["transform_delta_z_mm"] = transform_result.get("delta_z_mm", "")
        log_row["transform_rotation_1_rad"] = transform_result.get("rotation_1_rad", "")
        log_row["transform_rotation_2_rad"] = transform_result.get("rotation_2_rad", "")

        debug_event(
            "TRANSFORM_AFTER",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            target_frame_for_alignment,
            "After transform of copied replacement only",
            "transform_result={} | replacement={}".format(safe_str(transform_result), body_summary_for_debug(replacement_copy))
        )

        if TAG_IMPORTED_REPLACEMENT_BODY:
            target_instance_label = make_target_instance_label(target_sig, target_plan_id)
            new_name = "{}_{}_AT_{}".format(
                FINAL_REPLACEMENT_PREFIX.rstrip("_"),
                make_safe_name(safe_str(db_row.get("file_key", "DB"))),
                target_instance_label
            )
            set_name(replacement_copy, new_name)

        log_row["replacement_body_name"] = get_name(replacement_copy)
        log_row["baked_replacement_body_name"] = get_name(replacement_copy)

        debug_event(
            "FINAL_REPLACEMENT_READY",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            target_frame_for_alignment,
            "Final replacement body ready before target action",
            body_summary_for_debug(replacement_copy)
        )

        target_action = apply_original_after_replacement_action(target_body, db_row)
        log_row["target_action"] = target_action

        debug_event(
            "TARGET_ACTION_DONE",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            None,
            "Original target action applied",
            "action={}".format(target_action)
        )

        log_row["replaced"] = 1
        append_log(log_row)
        delete_temporary_planes(temp_planes)

        debug_event(
            "REPLACE_SUCCESS",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            replacement_copy,
            None,
            "Replacement finished successfully",
            ""
        )

        return True

    except Exception as e:
        log_row["error_message"] = safe_str(e)
        append_log(log_row)
        delete_temporary_planes(temp_planes)

        debug_event(
            "REPLACE_FAILED",
            target_plan_id,
            target_body,
            target_sig,
            db_row,
            None,
            None,
            "Replacement failed",
            safe_str(e)
        )

        print("Replacement failed for {}: {}".format(target_sig.get("body_name"), e))
        return False

def prepare_templates_for_plan(plan):
    """
    Preload one template per unique database item used in the frozen plan.
    Planning is already complete at this point, so template bodies cannot pollute
    match detection.
    """
    template_cache = {}
    needed = []
    used = {}

    for item in plan:
        db_row = item.get("db_row")
        key = db_template_key(db_row)
        if key not in used:
            used[key] = True
            needed.append(db_row)

    print("")
    print("Preparing V10 database templates: {} unique database item(s)".format(len(needed)))

    for db_row in needed:
        key = db_template_key(db_row)
        print("  preparing template: {}".format(key))
        prepare_database_template_for_row(db_row, template_cache)

    return template_cache

def locate_and_replace_dirty_instances():
    init_full_txt_log()
    append_full_txt_log("RUN_START", "Starting locate_and_replace_dirty_instances V19 second pass / ANSYS25 V251")

    db_rows = read_database_original_solids()
    append_full_txt_log("DATABASE_ROWS_LOADED", "count={}".format(len(db_rows)))
    if len(db_rows) == 0:
        print("No original_solid rows found in database.")
        append_full_txt_log("RUN_ABORT", "No original_solid rows found in database")
        return

    init_log()
    init_diagnostic_logs()

    # Snapshot before importing any replacement file.
    bodies = get_all_bodies()

    print("")
    print("Starting locate and replace V19 - second pass / ANSYS 25 V251")
    print("Assembly bodies snapshot: {}".format(len(bodies)))
    print("Database rows: {}".format(len(db_rows)))
    print("")

    plan, processed, accepted_count, rejected_count, skipped_count = build_replacement_plan_from_initial_snapshot(
        bodies,
        db_rows
    )

    print_plan_summary(plan)

    template_cache = {}
    if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW and len(plan) > 0:
        template_cache = prepare_templates_for_plan(plan)

    replaced_count = 0
    failed_count = 0
    match_index = 0

    for item in plan:
        if MAX_REPLACEMENTS > 0 and replaced_count >= MAX_REPLACEMENTS:
            break

        match_index += 1

        body = item.get("body")
        target_sig = item.get("target_sig")
        db_row = item.get("db_row")
        score = item.get("score")
        target_frame_snapshot = item.get("target_frame")
        target_vertex_cloud_snapshot = item.get("target_vertex_cloud", [])
        target_plan_id = item.get("plan_id", "")

        print("")
        print("REPLACING PLANNED MATCH {}/{}".format(match_index, len(plan)))
        print("Plan ID: {}".format(target_plan_id))
        print("Target: {}".format(target_sig.get("body_name")))
        print("DB key: {}".format(db_row.get("file_key")))

        if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW:
            ok = replace_one_target_body_from_template(
                body,
                target_sig,
                db_row,
                score,
                match_index,
                target_frame_snapshot,
                target_plan_id,
                template_cache,
                target_vertex_cloud_snapshot
            )
        else:
            ok = replace_one_target_body(body, target_sig, db_row, score, match_index, target_frame_snapshot, target_plan_id)

        if ok:
            replaced_count += 1
        else:
            failed_count += 1

    template_cleanup_summary = {}
    if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW:
        template_cleanup_summary = cleanup_database_templates_after_workflow(template_cache)

    # ============================================================
    # Second planning/replacement pass
    # ============================================================
    # Why:
    # Some valid repeated instances can be skipped in pass 1 because they live
    # under a component path/name that also appears in the database/template.
    # Pass 2 runs only after template cleanup and relaxes only those two skip
    # rules. The geometric matcher and existing-replacement guard still decide
    # whether a body is actually replaced.
    second_pass_processed = 0
    second_pass_accepted = 0
    second_pass_rejected = 0
    second_pass_skipped = 0
    second_pass_replaced = 0
    second_pass_failed = 0
    second_template_cleanup_summary = {}

    if ENABLE_SECOND_REPLACEMENT_SCAN:
        try:
            append_full_txt_log(
                "SECOND_PASS_START",
                "rescan after first pass | current_replaced={} | allow_db_path={} | allow_db_name={}".format(
                    replaced_count,
                    SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS,
                    SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS
                )
            )

            global CURRENT_SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS
            global CURRENT_SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS
            CURRENT_SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS = SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS
            CURRENT_SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS = SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS

            second_bodies = get_all_bodies()
            second_plan, second_pass_processed, second_pass_accepted, second_pass_rejected, second_pass_skipped = build_replacement_plan_from_initial_snapshot(
                second_bodies,
                db_rows
            )

            CURRENT_SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS = False
            CURRENT_SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS = False

            append_full_txt_log(
                "SECOND_PASS_PLAN_DONE",
                "bodies={} | processed={} | accepted={} | rejected={} | skipped={}".format(
                    len(second_bodies),
                    second_pass_processed,
                    second_pass_accepted,
                    second_pass_rejected,
                    second_pass_skipped
                )
            )

            second_template_cache = {}
            if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW and len(second_plan) > 0:
                second_template_cache = prepare_templates_for_plan(second_plan)

            second_match_index = 0
            for second_item in second_plan:
                if MAX_REPLACEMENTS > 0 and replaced_count >= MAX_REPLACEMENTS:
                    break

                second_match_index += 1
                match_index += 1

                body = second_item.get("body")
                target_sig = second_item.get("target_sig")
                db_row = second_item.get("db_row")
                score = second_item.get("score")
                target_frame_snapshot = second_item.get("target_frame")
                target_vertex_cloud_snapshot = second_item.get("target_vertex_cloud", [])
                target_plan_id = "PASS2_" + second_item.get("plan_id", "")

                print("")
                print("REPLACING SECOND-PASS MATCH {}/{}".format(second_match_index, len(second_plan)))
                print("Plan ID: {}".format(target_plan_id))
                print("Target: {}".format(target_sig.get("body_name")))
                print("DB key: {}".format(db_row.get("file_key")))

                if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW:
                    ok = replace_one_target_body_from_template(
                        body,
                        target_sig,
                        db_row,
                        score,
                        match_index,
                        target_frame_snapshot,
                        target_plan_id,
                        second_template_cache,
                        target_vertex_cloud_snapshot
                    )
                else:
                    ok = replace_one_target_body(body, target_sig, db_row, score, match_index, target_frame_snapshot, target_plan_id)

                if ok:
                    replaced_count += 1
                    second_pass_replaced += 1
                else:
                    failed_count += 1
                    second_pass_failed += 1

            if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW:
                second_template_cleanup_summary = cleanup_database_templates_after_workflow(second_template_cache)

            append_full_txt_log(
                "SECOND_PASS_DONE",
                "accepted={} | replaced={} | failed={}".format(
                    second_pass_accepted,
                    second_pass_replaced,
                    second_pass_failed
                )
            )

            processed += second_pass_processed
            accepted_count += second_pass_accepted
            rejected_count += second_pass_rejected
            skipped_count += second_pass_skipped

        except Exception as e:
            CURRENT_SECOND_PASS_ALLOW_DATABASE_COMPONENT_PATH_TARGETS = False
            CURRENT_SECOND_PASS_ALLOW_DATABASE_BODY_NAME_TARGETS = False
            append_full_txt_log_exception("SECOND_PASS_EXCEPTION", e)
            print("Second pass failed: {}".format(e))

    msg = ""
    msg += "Locate and replace finished.\n\n"
    msg += "Database rows: {}\n".format(len(db_rows))
    msg += "Bodies in initial snapshot: {}\n".format(len(bodies))
    msg += "Processed candidates: {}\n".format(processed)
    msg += "Matches accepted/planned: {}\n".format(accepted_count)
    msg += "Replacements completed: {}\n".format(replaced_count)
    msg += "Replacement failures: {}\n".format(failed_count)
    if ENABLE_SECOND_REPLACEMENT_SCAN:
        msg += "Second pass accepted/planned: {}\n".format(second_pass_accepted)
        msg += "Second pass replacements completed: {}\n".format(second_pass_replaced)
        msg += "Second pass replacement failures: {}\n".format(second_pass_failed)
    if USE_TEMPLATE_COPY_PER_OCCURRENCE_WORKFLOW:
        msg += "Template cleanup action: {}\n".format(template_cleanup_summary.get("action", ""))
        msg += "Template bodies found: {}\n".format(template_cleanup_summary.get("template_bodies", 0))
        msg += "Template component candidates: {}\n".format(template_cleanup_summary.get("template_components", 0))
        msg += "Safe template components: {}\n".format(template_cleanup_summary.get("safe_component_candidates", 0))
        msg += "Template components deleted: {}\n".format(template_cleanup_summary.get("component_deleted", 0))
        msg += "Template body direct deletes: {}\n".format(template_cleanup_summary.get("body_deleted", 0))
        msg += "Template body hidden fallback: {}\n".format(template_cleanup_summary.get("body_hidden", 0))
        msg += "Template direct body delete skipped: {}\n".format(template_cleanup_summary.get("direct_body_delete_skipped", 0))
        msg += "Template cleanup failures: {}\n".format(template_cleanup_summary.get("failed", 0))
    msg += "Rejected candidates: {}\n".format(rejected_count)
    msg += "Skipped bodies: {}\n".format(skipped_count)
    msg += "Log:\n{}\n".format(REPLACEMENT_LOG_CSV)
    if ENABLE_FULL_TXT_LOG:
        msg += "Full TXT debug log:\n{}\n".format(FULL_TXT_LOG_PATH)
    if ENABLE_DIAGNOSTIC_LOGS:
        msg += "Diagnostic event log:\n{}\n".format(DIAGNOSTIC_EVENT_LOG_CSV)
        msg += "Diagnostic plan log:\n{}".format(DIAGNOSTIC_PLAN_LOG_CSV)

    append_full_txt_log("RUN_SUMMARY", msg.replace("\n", " | "))

    print("")
    print(msg)

    try:
        MessageBox.Show(msg)
    except:
        pass

