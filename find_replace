def make_target_instance_label(target_sig, target_plan_id):
    """
    Builds a short occurrence-level label for logs and final replacement names.

    Important:
    body_name alone is not reliable because several occurrences may share the
    same name/master. The plan id is unique and the center helps auditing.
    """
    try:
        base = make_safe_name(target_sig.get("body_name", "TARGET"))
        cx = format_float3(target_sig.get("center_x_mm", ""))
        cy = format_float3(target_sig.get("center_y_mm", ""))
        cz = format_float3(target_sig.get("center_z_mm", ""))

        # Keep it short enough for the tree.
        return "{}_{}_C{}_{}_{}".format(base, safe_str(target_plan_id), cx, cy, cz)
    except:
        return "TARGET_{}".format(safe_str(target_plan_id))

def make_unique_temp_import_file(db_file_path, db_row, target_plan_id):
    """
    Copies the database .scdocx to a unique temporary filename before importing.

    Why:
    In SpaceClaim/Discovery, inserting the same .scdocx many times can reuse a
    dependent component definition. Then moving the newly inserted body can also
    affect previously inserted replacements. A unique file path per occurrence
    forces the import to behave as an independent set.

    Returns:
        path_to_insert, path_source_label
    """
    if not USE_UNIQUE_TEMP_IMPORT_COPY_PER_PLAN:
        return db_file_path, "original_database_file"

    if db_file_path is None or safe_str(db_file_path) == "":
        return db_file_path, "empty_database_file_path"

    if not os.path.exists(db_file_path):
        return db_file_path, "missing_original_database_file"

    try:
        if not os.path.exists(UNIQUE_TEMP_IMPORT_FOLDER):
            os.makedirs(UNIQUE_TEMP_IMPORT_FOLDER)
    except:
        pass

    db_key = safe_str(db_row.get("file_key", "DB"))
    if db_key == "":
        db_key = safe_str(db_row.get("body_name", "DB"))

    db_key = make_safe_name(db_key)
    plan_key = make_safe_name(target_plan_id)

    ext = os.path.splitext(db_file_path)[1]
    if ext == "":
        ext = ".scdocx"

    unique_name = "{}_{}{}".format(db_key, plan_key, ext)
    unique_path = os.path.join(UNIQUE_TEMP_IMPORT_FOLDER, unique_name)

    try:
        shutil.copy2(db_file_path, unique_path)
        return unique_path, "unique_temp_copy_from_database_file"
    except Exception as e:
        print("Could not create unique import copy. Falling back to original file: {}".format(e))
        return db_file_path, "unique_temp_copy_failed_fallback_original"

def cleanup_unique_temp_import_file(unique_path, db_file_path):
    """
    Optional cleanup. Default is False because some SpaceClaim sessions may keep
    a relation to the inserted file during the current session.
    """
    if not DELETE_UNIQUE_TEMP_IMPORT_FILES_AFTER_INSERT:
        return

    try:
        if unique_path and unique_path != db_file_path and os.path.exists(unique_path):
            os.remove(unique_path)
    except Exception as e:
        print("Could not delete temporary import file {}: {}".format(unique_path, e))

