def round_key_value(value, ndigits):
    try:
        if value is None:
            return ""
        return str(round(float(value), ndigits))
    except:
        return safe_str(value)

def body_snapshot_token(body):
    """
    Stable-enough token for detecting bodies that already existed before import.

    It intentionally combines:
        - name
        - ExportIdentifier if available
        - center rounded in mm
        - AABB rounded in mm
        - face/edge counts

    This avoids relying only on object identity, which can be unstable after
    DocumentInsert/InsertFile in SpaceClaim.
    """
    try:
        sig = build_body_signature(body)

        parts = [
            make_safe_name(get_name(body)),
            get_export_identifier(body),
            round_key_value(sig.get("center_x_mm"), 3),
            round_key_value(sig.get("center_y_mm"), 3),
            round_key_value(sig.get("center_z_mm"), 3),
            round_key_value(sig.get("aabb_min_mm"), 3),
            round_key_value(sig.get("aabb_mid_mm"), 3),
            round_key_value(sig.get("aabb_max_mm"), 3),
            safe_str(sig.get("num_faces", "")),
            safe_str(sig.get("num_edges", "")),
            safe_str(sig.get("num_planar_faces", "")),
            safe_str(sig.get("num_cylindrical_faces", ""))
        ]

        return "|".join(parts)

    except:
        # Fallback is still better than direct object comparison.
        try:
            return make_safe_name(get_name(body)) + "|" + safe_str(body.GetHashCode())
        except:
            return make_safe_name(get_name(body)) + "|" + safe_str(id(body))

def make_body_snapshot_tokens(bodies):
    tokens = {}
    for b in bodies:
        try:
            token = body_snapshot_token(b)
            if token != "":
                tokens[token] = True
        except:
            pass
    return tokens

def is_macro_generated_body_name(name):
    """
    Bodies created by the macro in previous plans must never be selected as fresh
    imported database bodies for the next plan.
    """
    n = safe_str(name).upper()

    prefixes = [
        "DB_REPLACEMENT_",
        "DB_SOURCE_ORIGINAL_",
        "DB_LINKED_IMPORT_",
        "REPLACED_BY_DB_",
        "TMP_MATCH_"
    ]

    for p in prefixes:
        if n.startswith(p):
            return True

    return False

def filter_fresh_imported_bodies_after_insert(before_snapshot_tokens):
    after_bodies = get_all_bodies()
    fresh = []
    rejected_old_or_macro = 0

    for b in after_bodies:
        try:
            name = get_name(b)

            # Never consider previous macro products as imported bodies for this plan.
            if is_macro_generated_body_name(name):
                rejected_old_or_macro += 1
                continue

            token = body_snapshot_token(b)

            if token not in before_snapshot_tokens:
                fresh.append(b)
        except:
            pass

    return fresh, rejected_old_or_macro

def add_body_unique_by_identity(body, bodies, keys):
    if body is None:
        return

    key = ""
    try:
        key = safe_str(get_export_identifier(body))
    except:
        key = ""

    if key == "":
        try:
            key = safe_str(body.GetHashCode())
        except:
            key = ""

    if key == "":
        try:
            key = safe_str(id(body))
        except:
            key = safe_str(body)

    if key != "" and key not in keys:
        keys[key] = True
        bodies.append(body)


def collect_bodies_from_component_like(obj, bodies, keys):
    if obj is None:
        return

    # Direct component methods.
    try:
        for b in obj.GetAllBodies():
            add_body_unique_by_identity(b, bodies, keys)
    except:
        pass

    try:
        for b in obj.GetBodies():
            add_body_unique_by_identity(b, bodies, keys)
    except:
        pass

    # Common SpaceClaim component Content tree.
    try:
        content = obj.Content
        try:
            for b in content.Bodies:
                add_body_unique_by_identity(b, bodies, keys)
        except:
            pass
        try:
            for b in content.GetAllBodies():
                add_body_unique_by_identity(b, bodies, keys)
        except:
            pass
    except:
        pass

    # Child components recursion.
    try:
        for child in obj.Components:
            collect_bodies_from_component_like(child, bodies, keys)
    except:
        pass

LAST_INSERT_CREATED_COMPONENTS = []
LAST_INSERT_COMPONENT_DETAIL = ""

def add_object_unique_by_identity(obj, objects, keys):
    if obj is None:
        return

    key = ""
    try:
        key = safe_str(get_export_identifier(obj))
    except:
        key = ""

    if key == "":
        try:
            key = safe_str(obj.GetHashCode())
        except:
            key = ""

    if key == "":
        try:
            key = safe_str(id(obj))
        except:
            key = safe_str(obj)

    if key != "" and key not in keys:
        keys[key] = True
        objects.append(obj)


def collect_components_recursive(obj, components, keys):
    if obj is None:
        return

    try:
        for c in obj.GetAllComponents():
            add_object_unique_by_identity(c, components, keys)
    except:
        pass

    try:
        for c in obj.Components:
            add_object_unique_by_identity(c, components, keys)
            collect_components_recursive(c, components, keys)
    except:
        pass

    try:
        content = obj.Content
        try:
            for c in content.Components:
                add_object_unique_by_identity(c, components, keys)
                collect_components_recursive(c, components, keys)
        except:
            pass
    except:
        pass


def get_all_components_safe():
    components = []
    keys = {}

    try:
        root = GetRootPart()
        collect_components_recursive(root, components, keys)
    except:
        pass

    return components


def make_object_key_dict(objects):
    keys = {}
    for obj in objects:
        try:
            key = ""
            try:
                key = safe_str(get_export_identifier(obj))
            except:
                key = ""
            if key == "":
                try:
                    key = safe_str(obj.GetHashCode())
                except:
                    key = ""
            if key == "":
                try:
                    key = safe_str(id(obj))
                except:
                    key = safe_str(obj)
            if key != "":
                keys[key] = True
        except:
            pass
    return keys


def filter_fresh_components_after_insert(before_component_keys):
    fresh = []
    keys = {}
    try:
        for c in get_all_components_safe():
            key = ""
            try:
                key = safe_str(get_export_identifier(c))
            except:
                key = ""
            if key == "":
                try:
                    key = safe_str(c.GetHashCode())
                except:
                    key = ""
            if key == "":
                try:
                    key = safe_str(id(c))
                except:
                    key = safe_str(c)
            if key != "" and key not in before_component_keys:
                add_object_unique_by_identity(c, fresh, keys)
    except:
        pass
    return fresh

def get_created_bodies_from_insert_result(result):
    global LAST_INSERT_CREATED_COMPONENTS

    bodies = []
    keys = {}
    LAST_INSERT_CREATED_COMPONENTS = []

    if result is None:
        return bodies

    # Most useful path: GetCreated[DesignBody]().
    try:
        for b in result.GetCreated[DesignBody]():
            add_body_unique_by_identity(b, bodies, keys)
    except:
        pass

    # Other possible properties depending on SpaceClaim/Discovery build.
    for attr in ["CreatedBodies", "Bodies", "CreatedDesignBodies"]:
        try:
            values = getattr(result, attr)
            if values is not None:
                for b in values:
                    add_body_unique_by_identity(b, bodies, keys)
        except:
            pass

    # Created components may contain the bodies.
    created_components = []

    try:
        for c in result.GetCreated[Component]():
            created_components.append(c)
    except:
        pass

    for attr in ["CreatedComponents", "Components"]:
        try:
            values = getattr(result, attr)
            if values is not None:
                for c in values:
                    created_components.append(c)
        except:
            pass

    component_keys = {}
    for c in created_components:
        add_object_unique_by_identity(c, LAST_INSERT_CREATED_COMPONENTS, component_keys)
        collect_bodies_from_component_like(c, bodies, keys)

    # Final filter: result-created bodies still must not be previous macro products.
    clean = []
    clean_keys = {}
    for b in bodies:
        try:
            if is_macro_generated_body_name(get_name(b)):
                continue
            add_body_unique_by_identity(b, clean, clean_keys)
        except:
            pass

    return clean


def insert_database_file_into_current_document(file_path):
    global LAST_INSERT_CREATED_COMPONENTS
    global LAST_INSERT_COMPONENT_DETAIL

    LAST_INSERT_CREATED_COMPONENTS = []
    LAST_INSERT_COMPONENT_DETAIL = ""

    before_bodies = get_all_bodies()
    before_snapshot_tokens = make_body_snapshot_tokens(before_bodies)
    before_component_keys = make_object_key_dict(get_all_components_safe())

    if not os.path.exists(file_path):
        raise Exception("Database item file does not exist: " + file_path)

    last_error = ""

    def after_insert_result(method_name, result_obj=None):
        global LAST_INSERT_CREATED_COMPONENTS
        global LAST_INSERT_COMPONENT_DETAIL

        result_bodies = []
        if PREFER_IMPORT_RESULT_CREATED_BODIES:
            result_bodies = get_created_bodies_from_insert_result(result_obj)

        if len(LAST_INSERT_CREATED_COMPONENTS) == 0:
            fresh_components = filter_fresh_components_after_insert(before_component_keys)
            LAST_INSERT_CREATED_COMPONENTS = fresh_components
            LAST_INSERT_COMPONENT_DETAIL = "snapshot_fresh_components={}".format(len(fresh_components))
        else:
            LAST_INSERT_COMPONENT_DETAIL = "result_created_components={}".format(len(LAST_INSERT_CREATED_COMPONENTS))

        if len(result_bodies) > 0:
            detail = "{} | result_created_bodies={} | {} | snapshot_fallback_used=0".format(
                method_name,
                len(result_bodies),
                LAST_INSERT_COMPONENT_DETAIL
            )
            append_full_txt_log("IMPORT_RESULT", detail)
            return result_bodies, detail

        fresh, rejected_old_or_macro = filter_fresh_imported_bodies_after_insert(before_snapshot_tokens)
        detail = "{} | result_created_bodies=0 | snapshot_fresh_bodies={} | rejected_old_or_macro={} | {} | snapshot_fallback_used=1".format(
            method_name,
            len(fresh),
            rejected_old_or_macro,
            LAST_INSERT_COMPONENT_DETAIL
        )
        append_full_txt_log("IMPORT_RESULT", detail)
        return fresh, detail

    # Candidate 1: common SpaceClaim insert command name.
    try:
        options = ImportOptions.Create()
        result = DocumentInsert.Execute(file_path, options)
        return after_insert_result("DocumentInsert.Execute(file, ImportOptions)", result)
    except Exception as e:
        last_error = safe_str(e)

    # Candidate 2: same command without options.
    try:
        result = DocumentInsert.Execute(file_path)
        return after_insert_result("DocumentInsert.Execute(file)", result)
    except Exception as e:
        last_error = safe_str(e)

    # Candidate 3: some versions expose InsertFile.
    try:
        options = ImportOptions.Create()
        result = InsertFile.Execute(file_path, options)
        return after_insert_result("InsertFile.Execute(file, ImportOptions)", result)
    except Exception as e:
        last_error = safe_str(e)

    # Candidate 4: no options.
    try:
        result = InsertFile.Execute(file_path)
        return after_insert_result("InsertFile.Execute(file)", result)
    except Exception as e:
        last_error = safe_str(e)

    raise Exception("Could not insert database item file. Last API error: " + last_error)


def imported_candidate_allowed(body):
    """
    V8: imported candidate must be one of the fresh bodies detected after this import,
    and must not be a product from a previous replacement plan.
    """
    try:
        name = get_name(body)
        if is_macro_generated_body_name(name):
            return False
        return True
    except:
        return False

def choose_imported_original_body(new_bodies, db_row):
    wanted = safe_str(db_row.get("body_name", ""))
    best = None

    for b in new_bodies:
        if not imported_candidate_allowed(b):
            continue

        sig = build_body_signature(b)

        if sig.get("body_role_guess") != "original_solid":
            continue

        name = get_name(b)

        # Exact wanted name wins.
        if wanted != "" and name == wanted:
            return b

        # Otherwise first fresh original solid.
        if best is None:
            best = b

    return best

def choose_imported_treated_surface_body(new_bodies, db_row):
    wanted = safe_str(db_row.get("paired_treated_surface_body_name", ""))
    best = None
    fallback_surface_like = None

    for b in new_bodies:
        if not imported_candidate_allowed(b):
            continue

        sig = build_body_signature(b)
        name = get_name(b)
        role = sig.get("body_role_guess")

        if role == "treated_surface":
            if wanted != "" and name == wanted:
                return b
            if best is None:
                best = b

        # Keep a fallback, but only among this plan's fresh imported bodies.
        try:
            vol = safe_float(sig.get("body_volume_mm3"), 1.0)
            aabb_min = safe_float(sig.get("aabb_min_mm"), 999999.0)
            if vol == 0.0 or aabb_min <= SURFACE_AABB_MIN_EPS_MM:
                if fallback_surface_like is None:
                    fallback_surface_like = b
        except:
            pass

    if best is not None:
        return best

    return fallback_surface_like

