def get_center_mm(body):
    try:
        bbox = body.Shape.GetBoundingBox(Matrix.Identity)
        c = bbox.Center
        return c.X * 1000.0, c.Y * 1000.0, c.Z * 1000.0
    except:
        return None, None, None

def get_inertia_signature_from_aabb(aabb):
    x = aabb.get("aabb_x_mm")
    y = aabb.get("aabb_y_mm")
    z = aabb.get("aabb_z_mm")

    if x is None or y is None or z is None:
        return None, None, None

    ixx = y * y + z * z
    iyy = x * x + z * z
    izz = x * x + y * y

    vals = sorted([ixx, iyy, izz])
    s = vals[0] + vals[1] + vals[2]

    if abs(s) < 1e-12:
        return None, None, None

    return vals[0] / s, vals[1] / s, vals[2] / s

def classify_body_role(aabb, volume, num_faces):
    try:
        if volume is None:
            volume = 0.0

        aabb_min = aabb.get("aabb_min_mm")

        if abs(float(volume)) <= SURFACE_VOLUME_EPS_MM3:
            return "treated_surface"
        if aabb_min is not None and abs(float(aabb_min)) <= SURFACE_AABB_MIN_EPS_MM:
            return "treated_surface"
        if num_faces <= 2 and abs(float(volume)) <= SURFACE_VOLUME_EPS_MM3:
            return "treated_surface"

        return "original_solid"
    except:
        return "unknown"

def build_body_signature(body):
    aabb = get_body_aabb_mm(body)
    face_counts = get_face_type_counts(body)
    i1, i2, i3 = get_inertia_signature_from_aabb(aabb)
    cx, cy, cz = get_center_mm(body)

    row = {}
    row["body_name"] = get_name(body)
    row["body_role_guess"] = classify_body_role(aabb, get_body_volume_mm3(body), get_num_faces(body))
    row["num_faces"] = get_num_faces(body)
    row["num_edges"] = get_num_edges(body)
    row["num_planar_faces"] = face_counts.get("Plane", 0)
    row["num_cylindrical_faces"] = face_counts.get("Cylinder", 0)
    row["num_conical_faces"] = face_counts.get("Cone", 0)
    row["num_toroidal_faces"] = face_counts.get("Torus", 0)
    row["body_surface_area_mm2"] = get_body_surface_area_mm2(body)
    row["body_volume_mm3"] = get_body_volume_mm3(body)

    for k in aabb:
        row[k] = aabb[k]

    row["center_x_mm"] = cx
    row["center_y_mm"] = cy
    row["center_z_mm"] = cz
    row["inertia_norm_1"] = i1
    row["inertia_norm_2"] = i2
    row["inertia_norm_3"] = i3
    return row

