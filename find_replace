def make_body_snapshot_token_dict_from_bodies(bodies):

    tokens = {}
    for b in bodies:
        try:
            token = body_snapshot_token(b)
            if token != "":
                tokens[token] = True
        except:
            pass
    return tokens

def component_is_safe_template_container(component_candidate, template_body_keys, template_body_tokens=None):

    comp_bodies = get_bodies_from_component_candidate(component_candidate)
    if len(comp_bodies) == 0:
        return False, "no bodies found inside candidate", comp_bodies

    if template_body_tokens is None:
        template_body_tokens = {}

    matched = 0
    matched_by_identity = 0
    matched_by_token = 0
    foreign = []

    for b in comp_bodies:
        try:
            bkey = object_identity_key(b)
            bname = get_name(b)
            btoken = ""
            if TEMPLATE_COMPONENT_SAFETY_USES_BODY_SNAPSHOT_TOKENS:
                try:
                    btoken = body_snapshot_token(b)
                except:
                    btoken = ""

            if bkey != "" and bkey in template_body_keys:
                matched += 1
                matched_by_identity += 1
                continue

            if btoken != "" and btoken in template_body_tokens:
                matched += 1
                matched_by_token += 1
                continue

            # A final replacement inside the candidate is an automatic rejection.
            if starts_with_any(bname, [FINAL_REPLACEMENT_PREFIX, "DB_REPLACEMENT_"]):
                foreign.append("FINAL:" + body_summary_for_debug(b))
            else:
                foreign.append(body_summary_for_debug(b))
        except Exception as e:
            foreign.append("error evaluating body: " + safe_str(e))

    if matched == 0:
        return False, "candidate has no cached template bodies by identity or snapshot token", comp_bodies

    if len(foreign) > 0:
        return False, "candidate has foreign bodies: " + " || ".join(foreign), comp_bodies

    return True, "safe template container with {} body/bodies | matched_identity={} | matched_token={}".format(matched, matched_by_identity, matched_by_token), comp_bodies

def try_direct_delete_object(obj, label):

    attempts = []

    def add_attempt(name, func):
        attempts.append((name, func))

    add_attempt(
        "Selection.Create(obj)",
        lambda: Delete.Execute(Selection.Create(obj))
    )

    add_attempt(
        "Selection.Create([obj])",
        lambda: Delete.Execute(Selection.Create([obj]))
    )

    for attempt_name, func in attempts:
        try:
            append_full_txt_log("DELETE_ATTEMPT", "{} | {} | {}".format(label, attempt_name, object_summary_for_debug(obj)))
            func()
            append_full_txt_log("DELETE_OK", "{} | {} | {}".format(label, attempt_name, object_summary_for_debug(obj)))
            print("Deleted {} {} using {}".format(label, get_name(obj), attempt_name))
            return True, ""
        except Exception as e:
            append_full_txt_log("DELETE_ATTEMPT_FAILED", "{} | {} | {} | error={}".format(label, attempt_name, object_summary_for_debug(obj), safe_str(e)))

    append_full_txt_log("DELETE_FAILED_" + safe_str(label), object_summary_for_debug(obj))
    return False, "all delete attempts failed"

