def safe_str(value):
    try:
        if value is None:
            return ""
        return str(value).strip()
    except:
        return ""

def safe_float(value, default=None):
    try:
        if value is None:
            return default
        txt = safe_str(value).replace(",", ".")
        if txt == "":
            return default
        return float(txt)
    except:
        return default

def safe_int(value, default=0):
    try:
        return int(float(value))
    except:
        return default

def safe_div(a, b):
    try:
        if a is None or b is None:
            return None
        b = float(b)
        if abs(b) < 1e-12:
            return None
        return float(a) / b
    except:
        return None

def rel_err(a, b):
    try:
        a = safe_float(a)
        b = safe_float(b)
        if a is None or b is None:
            return 999.0
        denom = max(abs(a), abs(b), 1e-9)
        return abs(a - b) / denom
    except:
        return 999.0

def abs_err(a, b):
    try:
        a = safe_float(a)
        b = safe_float(b)
        if a is None or b is None:
            return 999999.0
        return abs(a - b)
    except:
        return 999999.0

