def db_template_key(db_row):
    """
    Unique logical key for one database item/template.
    """
    key = safe_str(db_row.get("file_key", ""))
    if key == "":
        key = safe_str(db_row.get("body_name", ""))
    if key == "":
        key = safe_str(db_row.get("pair_id", ""))
    if key == "":
        key = "DB_ITEM"
    return make_safe_name(key)

def apply_template_body_action(bodies, db_key):
    action = safe_str(TEMPLATE_BODY_ACTION_AFTER_IMPORT).upper()

    for b in bodies:
        try:
            old_name = get_name(b)
            if RENAME_TEMPLATE_BODIES_AFTER_IMPORT:
                if not starts_with_any(old_name, [TEMPLATE_COMPONENT_PREFIX]):
                    set_name(b, "{}{}_{}".format(TEMPLATE_COMPONENT_PREFIX, db_key, old_name))
                    append_full_txt_log("TEMPLATE_BODY_RENAMED", "db_key={} | old={} | new={}".format(db_key, old_name, get_name(b)))
            else:
                append_full_txt_log("TEMPLATE_BODY_RENAME_SKIPPED", "db_key={} | body={}".format(db_key, old_name))
        except Exception as e:
            append_full_txt_log_exception("TEMPLATE_BODY_RENAME_ERROR", e)

        if action == "HIDE":
            hide_item(b)
        elif action == "DELETE":
            # This is intentionally left as the old behavior only when the user
            # explicitly sets TEMPLATE_BODY_ACTION_AFTER_IMPORT='DELETE'. It is
            # not recommended for linked .scdocx templates.
            delete_item(b)
        else:
            pass

def object_identity_key(obj):
    if obj is None:
        return ""

    try:
        eid = safe_str(get_export_identifier(obj))
        if eid != "":
            return "EXP:" + eid
    except:
        pass

    try:
        key = safe_str(obj.GetHashCode())
        if key != "":
            return "HASH:" + key
    except:
        pass

    try:
        return "ID:" + safe_str(id(obj))
    except:
        return safe_str(obj)

def add_unique_object(obj, objects, keys):
    if obj is None:
        return

    key = object_identity_key(obj)
    if key == "":
        return
    if key not in keys:
        keys[key] = True
        objects.append(obj)

def safe_type_name(obj):
    try:
        return safe_str(obj.GetType().Name)
    except:
        try:
            return safe_str(type(obj).__name__)
        except:
            return ""

def object_summary_for_debug(obj):
    if obj is None:
        return "None"
    try:
        return "type={} | name={} | key={}".format(
            safe_type_name(obj),
            get_name(obj),
            object_identity_key(obj)
        )
    except:
        return safe_str(obj)

def objects_summary_for_debug(objects):
    try:
        parts = []
        for obj in objects:
            parts.append(object_summary_for_debug(obj))
        return " || ".join(parts)
    except:
        return ""

def get_template_body_parent_candidates(body):
    """
    Returns possible containers/components for a template body.
    Direct body deletion is what tends to trigger the SpaceClaim prompt asking
    to save changes in the inserted database item.
    """
    candidates = []
    keys = {}

    current = body
    depth = 0
    while current is not None and depth < 6:
        for attr in ["Parent", "Component"]:
            try:
                obj = getattr(current, attr)
                add_unique_object(obj, candidates, keys)
            except:
                pass
        try:
            current = current.Parent
        except:
            current = None
        depth += 1
    try:
        comp = body.GetAncestor[Component]()
        add_unique_object(comp, candidates, keys)
    except:
        pass
    return candidates

def get_bodies_from_component_candidate(component_candidate):
    bodies = []
    keys = {}
    try:
        collect_bodies_from_component_like(component_candidate, bodies, keys)
