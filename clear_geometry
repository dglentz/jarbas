def empty_selection_safe():
    try:
        return Selection.Empty()
    except:
        pass

    try:
        return Selection.Create([])
    except:
        pass

    try:
        return Selection()
    except:
        return None


def make_selection_safe(items):
    if items is None:
        return empty_selection_safe()

    # Item unico.
    try:
        if not isinstance(items, list):
            return Selection.Create(items)
    except:
        pass

    seq = list_from_iterable(items)

    if len(seq) == 0:
        return empty_selection_safe()

    if len(seq) == 1:
        try:
            return Selection.Create(seq[0])
        except:
            pass

    # No v25, algumas chamadas aceitam lista Python; outras aceitam *args.
    try:
        return Selection.Create(seq)
    except:
        pass

    try:
        return Selection.Create(*seq)
    except:
        pass

    try:
        return Selection.Create(items)
    except Exception as e:
        debug_log("[WARN] make_selection_safe falhou: {0}".format(e))

    return empty_selection_safe()


def create_body_selection(body):
    if body is None:
        return empty_selection_safe()

    selection = make_selection_safe(body)

    if selection is None:
