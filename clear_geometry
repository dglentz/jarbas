def sort_records_by_area_ascending(records):
    if records is None:
        return []

    records = list_from_iterable(records)
    n = len(records)

    for i in range(n):
        min_index = i

        for j in range(i + 1, n):
            if record_area(records[j]) < record_area(records[min_index]):
                min_index = j

        if min_index != i:
            temp = records[i]
            records[i] = records[min_index]
            records[min_index] = temp

    return records


def sort_records_by_area_descending(records):
    if records is None:
        return []

    records = list_from_iterable(records)
    n = len(records)

    for i in range(n):
        max_index = i

        for j in range(i + 1, n):
            if record_area(records[j]) > record_area(records[max_index]):
                max_index = j

        if max_index != i:
            temp = records[i]
            records[i] = records[max_index]
            records[max_index] = temp

    return records


def record_area_distance_to_target(record, target_area):
    area = record_area(record)

    if area >= target_area:
        return area - target_area

    return target_area - area


def sort_records_by_distance_to_target_area(records, target_area):
    if records is None:
        return []

    records = list_from_iterable(records)
    n = len(records)

    for i in range(n):
        best_index = i

        for j in range(i + 1, n):
            d_j = record_area_distance_to_target(records[j], target_area)
            d_best = record_area_distance_to_target(records[best_index], target_area)

            if d_j < d_best:
                best_index = j

        if best_index != i:
            temp = records[i]
            records[i] = records[best_index]
            records[best_index] = temp

    return records


def component_min_area(component):
    if component is None:
        return 0.0

    if len(component) == 0:
        return 0.0

    min_area = record_area(component[0])

    for i in range(1, len(component)):
        area = record_area(component[i])

        if area < min_area:
            min_area = area

    return min_area


def component_max_area(component):
    if component is None:
        return 0.0

    if len(component) == 0:
        return 0.0

    max_area = record_area(component[0])

    for i in range(1, len(component)):
        area = record_area(component[i])

        if area > max_area:
            max_area = area

    return max_area


def component_area_spread(component):
    return component_max_area(component) - component_min_area(component)


def sort_components_by_min_area(components):
    if components is None:
        return []

    components = list_from_iterable(components)
    n = len(components)

    for i in range(n):
        min_index = i

        for j in range(i + 1, n):
            if component_min_area(components[j]) < component_min_area(components[min_index]):
                min_index = j

        if min_index != i:
            temp = components[i]
            components[i] = components[min_index]
            components[min_index] = temp

    return components


