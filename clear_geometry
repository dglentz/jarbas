def collect_direct_bodies_from_container(container):
    out = []

    if container is None:
        return out

    candidates = ["GetBodies", "Bodies", "DesignBodies"]

    for i in range(len(candidates)):
        attr = candidates[i]
        try:
            items = get_collection_by_attr_or_method(container, attr)

            for j in range(len(items)):
                item = items[j]

                if looks_like_body(item):
                    out.append(item)
        except:
            pass

    return out


def collect_child_containers(container):
    out = []

    if container is None:
        return out

    attrs = [
        "GetComponents",
        "Components",
        "DesignComponents",
        "SubComponents",
        "Children",
        "GetChildren",
        "Occurrences",
        "Content"
    ]

    for i in range(len(attrs)):
        attr = attrs[i]

        if attr == "Content":
            content = get_content_object(container)

            if content is not None:
                out.append(content)

            continue

        try:
            items = get_collection_by_attr_or_method(container, attr)

            for j in range(len(items)):
                child = items[j]

                if child is not None:
                    out.append(child)

                content = get_content_object(child)

                if content is not None:
                    out.append(content)
        except:
            pass

    return out


def crawl_bodies_recursive(container, body_list, body_keys, visited_container_keys, depth, path_text):
    if container is None:
        return

    if depth > TREE_CRAWL_MAX_DEPTH:
        tree_log("[TREE] Profundidade maxima atingida em: {0}".format(path_text))
        return

    container_key = object_key_safe(container)

    if key_is_in_list(container_key, visited_container_keys):
        return

    visited_container_keys.append(container_key)

    current_name = safe_name(container)

    try:
        if path_text is None or path_text == "":
            next_path = current_name
        else:
            next_path = path_text + "/" + current_name
    except:
        next_path = current_name

    direct_bodies = collect_direct_bodies_from_container(container)

    for i in range(len(direct_bodies)):
        body = direct_bodies[i]
        added = append_unique_body(body_list, body, body_keys)

        if added and DEBUG_TREE_LOG:
            tree_log("[TREE] Body encontrado depth={0} path={1} body={2}".format(
                depth,
                next_path,
                safe_name(body)
            ))

    children = collect_child_containers(container)

    for i in range(len(children)):
        child = children[i]

        if child is None:
            continue

        if looks_like_body(child):
            added_body = append_unique_body(body_list, child, body_keys)

            if added_body and DEBUG_TREE_LOG:
                tree_log("[TREE] Body-child encontrado depth={0} path={1} body={2}".format(
                    depth,
                    next_path,
                    safe_name(child)
                ))

            continue

        crawl_bodies_recursive(
            child,
            body_list,
            body_keys,
            visited_container_keys,
            depth + 1,
            next_path
        )


def get_all_bodies_v25_tree_safe(root):
    bodies = []
    body_keys = []

    if root is None:
        return bodies

    get_all_count = 0
    recursive_count_before = 0

    try:
        all_bodies = list_from_iterable(root.GetAllBodies())
        get_all_count = len(all_bodies)

        for i in range(len(all_bodies)):
            append_unique_body(bodies, all_bodies[i], body_keys)
    except Exception as e:
        tree_log("[TREE] root.GetAllBodies() indisponivel/falhou: {0}".format(e))

    recursive_count_before = len(bodies)

    if ENABLE_TREE_RECURSIVE_FALLBACK:
        try:
            visited_container_keys = []
            crawl_bodies_recursive(
                root,
                bodies,
                body_keys,
                visited_container_keys,
                0,
                "ROOT"
            )
        except Exception as e:
            tree_log("[TREE] fallback recursivo falhou: {0}".format(e))

    if len(bodies) == 0:
        try:
            root_bodies = list_from_iterable(root.GetBodies())

            for i in range(len(root_bodies)):
                append_unique_body(bodies, root_bodies[i], body_keys)
        except Exception as e:
            log("[WARN] root.GetBodies() fallback final falhou: {0}".format(e))

    tree_log("[TREE] GetAllBodies={0} | antes_recursivo={1} | total_unicos={2}".format(
        get_all_count,
        recursive_count_before,
        len(bodies)
    ))

    return bodies


