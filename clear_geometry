def clean_rounds_at_radius(body, radius_mm):
    selection = get_round_selection_by_radius(body, radius_mm)

    ok = execute_fill(
        selection,
        "raios <= {0} mm em {1}".format(radius_mm, safe_name(body)),
        body
    )

    if ok:
        return True

    if not ENABLE_ROUND_INDIVIDUAL_FALLBACK:
        return False

    round_faces = get_items_from_selection(selection)

    if len(round_faces) == 0:
        return False

    removed_any = False

    for i in range(len(round_faces)):
        temp_records = []
        temp_records.append({
            "face": round_faces[i],
            "area_mm2": 0.0
        })

        ok_face = try_fill_records(
            temp_records,
            "raio individual <= {0} mm | face {1}/{2}".format(
                radius_mm,
                i + 1,
                len(round_faces)
            ),
            body,
            True
        )

        if ok_face:
            removed_any = True

    return removed_any


def clean_rounds_incremental(body):
    if body is None:
        return False

    removed_global = False

    for round_pass in range(ROUND_CLEAN_PASSES):
        log("")
        log("[ROUND PASS] Corpo '{0}' | volta {1}/{2}".format(
            safe_name(body),
            round_pass + 1,
            ROUND_CLEAN_PASSES
        ))

        removed_this_pass = False
        radius_mm = ROUND_INCREMENT_MM

        while radius_mm <= MAX_ROUND_RADIUS_MM + 1.0e-9:
            log("[ROUND STEP] Tentando remover raios <= {0} mm".format(radius_mm))

            ok = clean_rounds_at_radius(body, radius_mm)

            if ok:
                removed_this_pass = True
                removed_global = True

            radius_mm = radius_mm + ROUND_INCREMENT_MM

        if not removed_this_pass:
            log("[ROUND PASS] Nenhum raio removido nesta volta. Encerrando etapa de raios.")
            break

    return removed_global


