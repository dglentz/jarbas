    neighbors = []

    edges = get_edges_from_face(face)

    for i in range(len(edges)):
        edge = edges[i]
        edge_faces = get_faces_from_edge(edge)

        for j in range(len(edge_faces)):
            other_face = edge_faces[j]

            if face_is_same(other_face, face):
                continue

            rec = find_record_by_face(candidate_records, other_face)

            if rec is not None:
                append_record_unique(neighbors, rec)

    return neighbors


def build_chain_from_seed(seed_record, candidate_records, max_faces):
    chain = []
    queue = []

    append_record_unique(chain, seed_record)
    append_record_unique(queue, seed_record)

    while len(queue) > 0:
        current = queue[0]
        del queue[0]

        current_face = current["face"]
        neighbors = get_neighbor_records(current_face, candidate_records)

        for i in range(len(neighbors)):
            neighbor = neighbors[i]

            if not record_is_in_list(neighbor, chain):
                append_record_unique(chain, neighbor)
                append_record_unique(queue, neighbor)

                if len(chain) >= max_faces:
                    return chain

    return chain


