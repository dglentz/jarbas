def get_parent_candidate(obj):
    if obj is None:
        return None

    attrs = ["Parent", "Component", "Owner", "Container"]

    for i in range(len(attrs)):
        attr = attrs[i]

        try:
            parent = getattr(obj, attr)
            parent = parent() if callable(parent) else parent

            if parent is not None:
                return parent
        except:
            pass

    return None


def body_parent_path_text(body):
    names = []

    current = body
    visited = []
    depth = 0

    while current is not None and depth < TREE_CRAWL_MAX_DEPTH:
        key = object_key_safe(current)

        if key_is_in_list(key, visited):
            break

        visited.append(key)

        try:
            nm = safe_name(current)

            if nm is not None and nm != "" and nm != "None":
                names.append(nm)
        except:
            pass

        current = get_parent_candidate(current)
        depth = depth + 1

    text = ""

    # inverte sem sorted/reversed para manter compatibilidade
    for i in range(len(names) - 1, -1, -1):
        if text == "":
            text = names[i]
        else:
            text = text + "/" + names[i]

    return text


def body_filter_search_text(body):
    text = ""

    try:
        text = text + " " + safe_name(body)
    except:
        pass

    if BODY_FILTER_MATCH_COMPONENT_PATH:
        try:
            text = text + " " + body_parent_path_text(body)
        except:
            pass

    try:
        master = body.Master
        text = text + " " + safe_name(master)
    except:
        pass

    return text.upper()


def body_passes_name_filter(body):
    if BODY_NAME_FILTERS is None:
        return True

    if len(BODY_NAME_FILTERS) == 0:
        return True

    text = body_filter_search_text(body)

    for i in range(len(BODY_NAME_FILTERS)):
        token = BODY_NAME_FILTERS[i]

        try:
            if token is None:
                continue

            if str(token).upper() in text:
                return True
        except:
            pass

    return False


