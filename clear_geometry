def execute_fill_command_safe(selection):
    errors = []

    try:
        return Fill.Execute(
            selection,
            empty_selection_safe(),
            FillOptions(),
            FillMode.ThreeD
        )
    except Exception as e:
        errors.append("Fill.Execute(sel, empty, options, ThreeD): " + str(e))

    try:
        return Fill.Execute(
            selection,
            Selection(),
            FillOptions(),
            FillMode.ThreeD
        )
    except Exception as e:
        errors.append("Fill.Execute(sel, Selection(), options, ThreeD): " + str(e))

    try:
        return Fill.Execute(selection)
    except Exception as e:
        errors.append("Fill.Execute(sel): " + str(e))

    raise Exception("Fill falhou em todas as assinaturas: " + " | ".join(errors))


def execute_fill(selection, description, body):
    if selection is None:
        debug_log("[SKIP] Selection None: {0}".format(description))
        return False

    count = selection_count(selection)

    if count == 0:
        debug_log("[SKIP] Seleção vazia: {0}".format(description))
        return False

    if body is not None and not body_is_alive_light(body):
        debug_log("[SKIP] Corpo invalido antes do Fill: {0} | {1}".format(
            safe_name(body),
            description
        ))
        return False

    faces_before = get_body_face_count(body)

    try:
        result = execute_fill_command_safe(selection)
    except Exception as e:
        log("[FAIL] Fill exception em '{0}': {1}".format(description, e))
        return False

    faces_after = None

    try:
        faces_after = get_body_face_count(body)
    except Exception as e:
        log("[WARN] Não foi possível contar faces após Fill em '{0}': {1}".format(
            description,
            e
        ))

    result_success = True

    try:
        result_success = bool(result.Success)
    except:
        result_success = True

    if faces_before is not None and faces_after is not None:
        if faces_after < faces_before:
            log("[OK] Fill removeu faces: {0} | itens={1} | faces {2} -> {3}".format(
                description,
                count,
                faces_before,
                faces_after
            ))
            return True

        if result_success and faces_after != faces_before:
            log("[OK] Fill alterou topologia: {0} | itens={1} | faces {2} -> {3}".format(
                description,
                count,
                faces_before,
                faces_after
            ))
            return True

        log("[WARN] Fill sem redução: {0} | itens={1} | faces {2} -> {3}".format(
            description,
            count,
            faces_before,
            faces_after
        ))
        return False

    if result_success:
        log("[OK] Fill executado sem verificação topológica: {0} | itens={1}".format(
            description,
            count
        ))
        return True

    log("[WARN] Fill retornou sem sucesso explícito: {0} | itens={1}".format(
        description,
        count
    ))
    return False


def execute_delete(selection, description):
    if selection is None:
        return False

    count = selection_count(selection)

    if count == 0:
        return False

    try:
        result = Delete.Execute(selection)
