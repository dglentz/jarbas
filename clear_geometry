def collect_residual_edge_candidates(body):
    edges = get_edges_from_body(body)
    candidates = []

    for i in range(len(edges)):
        edge = edges[i]

        edge_faces = get_faces_from_edge(edge)

        if len(edge_faces) < 2:
            continue

        length_mm = get_edge_length_mm(edge)

        if length_mm is None:
            continue

        if length_mm > RESIDUAL_EDGE_MAX_LENGTH_MM:
            continue

        append_edge_unique(candidates, edge)

    return candidates


def find_shortest_edge_not_failed(edges, failed_edges):
    if edges is None:
        return None

    best_edge = None
    best_len = None

    for i in range(len(edges)):
        edge = edges[i]

        if edge_is_in_list(edge, failed_edges):
            continue

        length_mm = get_edge_length_mm(edge)

        if length_mm is None:
            continue

        if best_edge is None:
            best_edge = edge
            best_len = length_mm
            continue

        if length_mm < best_len:
            best_edge = edge
            best_len = length_mm

    return best_edge


def clean_residual_edges(body, stage_name):
    log("")
    log("------------------------------------------------------------")
    log("[{0}] Limpeza de arestas/linhas residuais".format(stage_name))
    log("------------------------------------------------------------")

    removed_any = False
    attempts = 0
    failed_edges = []

    while attempts < MAX_RESIDUAL_EDGE_ATTEMPTS:
        candidates = collect_residual_edge_candidates(body)

        edge_log("[EDGE] Arestas candidatas: {0}, falhadas={1}".format(
            len(candidates),
            len(failed_edges)
        ))

        if len(candidates) == 0:
            break

        edge = find_shortest_edge_not_failed(candidates, failed_edges)

        if edge is None:
            edge_log("[EDGE] Nenhuma aresta candidata restante após filtrar falhas.")
            break

        length_mm = get_edge_length_mm(edge)

        if length_mm is None:
            append_edge_unique(failed_edges, edge)
            continue

        attempts = attempts + 1

        desc = "aresta residual | stage={0}, tentativa={1}, length={2:.3f} mm em {3}".format(
            stage_name,
            attempts,
            length_mm,
            safe_name(body)
        )

        faces_before = get_body_face_count(body)

        ok_fill = try_fill_edges([edge], desc, body)

        faces_after = get_body_face_count(body)

        if ok_fill:
            removed_any = True
            failed_edges = []

            log("[EDGE] Aresta residual tratada. Faces {0} -> {1}".format(
                faces_before,
                faces_after
            ))

            continue

        append_edge_unique(failed_edges, edge)

        if ENABLE_EDGE_DELETE_FALLBACK:
            selection = create_selection_from_edges([edge])
            ok_delete = execute_delete(selection, desc + " | Delete fallback")

            if ok_delete:
                removed_any = True
                failed_edges = []
                continue

    return removed_any


