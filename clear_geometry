    if seed_area > DENT_SEED_MAX_AREA_MM2:
        return False

    neighbors = get_neighbor_records(seed_record["face"], member_records)
    neighbors = filter_records_that_are_in_chain(neighbors, chain)

    filtered = []

    for i in range(len(neighbors)):
        area = record_area(neighbors[i])

        if area < DENT_NEIGHBOR_MIN_AREA_MM2:
            continue

        if area > DENT_NEIGHBOR_MAX_AREA_MM2:
            continue

        append_record_unique(filtered, neighbors[i])

    filtered = sort_records_by_distance_to_target_area(
        filtered,
        DENT_NEIGHBOR_TARGET_AREA_MM2
    )

    feature_log("[DENT] seed_area={0:.3f}, vizinhos_filtrados={1}".format(
        seed_area,
        len(filtered)
    ))

    tries = 0

    for i in range(len(filtered)):
        if tries >= MAX_DENT_PAIR_TRIES:
            break

        neighbor = filtered[i]
        pair = []
        pair.append(seed_record)
        pair.append(neighbor)

        tries = tries + 1

        ok_pair = try_fill_records(
            pair,
            "{0} | par dente seed+vizinho | seed={1:.3f}, vizinho={2:.3f}".format(
                description_prefix,
                seed_area,
                record_area(neighbor)
            ),
            body,
            False
        )

        if ok_pair:
            return True

    if ENABLE_DENT_CONTROLLED_FALLBACK:
        fallback = first_n_records(chain, DENT_FALLBACK_MAX_FACES)

        if len(fallback) > 1:
            ok_fallback = try_fill_records(
                fallback,
                "{0} | fallback dente {1} faces | area_min={2:.3f}, area_max={3:.3f}".format(
                    description_prefix,
                    len(fallback),
                    component_min_area(fallback),
                    component_max_area(fallback)
                ),
                body,
                False
            )

            if ok_fallback:
                return True

    return False


def select_preferred_chain_variant(chain):
    if chain is None:
        return []

    chain_size = len(chain)

    if chain_size == 0:
        return []

    if chain_size == 1:
        if ALLOW_SINGLE_FACE_FILL:
            return first_n_records(chain, 1)
        return []

    min_area = component_min_area(chain)
    max_area = component_max_area(chain)
    spread = component_area_spread(chain)

    # Para dentes com microface, a seleção será tratada por try_dent_seed_neighbor_pairs.
    if min_area <= DENT_SEED_MAX_AREA_MM2 and max_area >= DENT_NEIGHBOR_MIN_AREA_MM2:
        return []

    if chain_size == 4:
        return first_n_records(chain, 3)

    if chain_size >= 5 and spread <= 1.0:
        return chain

    return chain


def try_chain_preferred_variant(seed_record, chain, member_records, body):
    if chain is None:
        return False

    chain_size = len(chain)

    if chain_size == 0:
        return False

    area_min = component_min_area(chain)
    area_max = component_max_area(chain)

    feature_log("[CHAIN] Cadeia candidata: faces={0}, area_min={1:.3f}, area_max={2:.3f}".format(
        chain_size,
        area_min,
        area_max
    ))

    # Nova prioridade para dentes:
    # tenta seed + vizinho com área mais próxima de ~77 mm².
    ok_dent = try_dent_seed_neighbor_pairs(
        seed_record,
        chain,
        member_records,
        body,
        "cadeia dente"
    )

    if ok_dent:
        return True

    preferred = select_preferred_chain_variant(chain)

    if preferred is None:
        return False

    if len(preferred) == 0:
        return False

    ok_preferred = try_fill_records(
        preferred,
        "cadeia preferencial | faces={0}, area_min={1:.3f}, area_max={2:.3f}".format(
            len(preferred),
            component_min_area(preferred),
            component_max_area(preferred)
        ),
        body,
        ALLOW_SINGLE_FACE_FILL
    )

    if ok_preferred:
        return True

    if not ENABLE_RISKY_FALLBACK_VARIANTS:
        return False

    n = 2

    while n <= chain_size:
        variant = first_n_records(chain, n)

        if len(variant) == len(preferred):
            n = n + 1
            continue

        ok_n = try_fill_records(
            variant,
            "cadeia fallback {0} faces | area_min={1:.3f}, area_max={2:.3f}".format(
                n,
                component_min_area(variant),
                component_max_area(variant)
            ),
            body,
            ALLOW_SINGLE_FACE_FILL
        )

        if ok_n:
            return True

        n = n + 1

    return False


def clean_one_chain_attempt(body, failed_signatures):
    protected = get_protected_faces(body)
    seeds = collect_seed_records(body, protected)
    member_records = collect_chain_member_records(body, protected)

    print_seed_summary(seeds, member_records, protected)

    if len(seeds) == 0:
        feature_log("[CHAIN] Nenhuma semente pequena encontrada.")
        return "NO_SEEDS"

    if len(member_records) == 0:
        feature_log("[CHAIN] Nenhum membro de cadeia encontrado.")
        return "NO_MEMBERS"

    for i in range(len(seeds)):
        seed = seeds[i]

        chain = build_chain_from_seed(seed, member_records, CHAIN_MAX_FACES)

        if len(chain) == 0:
            continue

        if len(chain) == 1 and not ALLOW_SINGLE_FACE_FILL:
            continue

        sig = chain_signature(chain)

        if signature_in_list(sig, failed_signatures):
            continue

        neighbor_count = len(chain) - 1

        feature_log("[CHAIN] Tentando seed {0}/{1}: seed_area={2:.3f}, vizinhos={3}, assinatura={4}".format(
            i + 1,
            len(seeds),
            seed["area_mm2"],
            neighbor_count,
            sig
        ))

        ok = try_chain_preferred_variant(
            seed,
            chain,
            member_records,
            body
        )

        if ok:
            return "REMOVED"

        failed_signatures.append(sig)
        return "FAILED"

    return "NO_VALID_CHAIN"


def clean_feature_chains(body):
    if not ENABLE_FEATURE_CHAIN_CLEAN:
        return False

    removed_global = False
    total_attempts = 0
    failed_signatures = []

    for pass_id in range(CHAIN_CLEAN_PASSES):
        log("")
        log("[CHAIN PASS] Corpo '{0}' | ciclo {1}/{2}".format(
            safe_name(body),
            pass_id + 1,
            CHAIN_CLEAN_PASSES
        ))

        removed_this_pass = False

        while total_attempts < MAX_CHAIN_ATTEMPTS_PER_BODY:
            total_attempts = total_attempts + 1

            faces_before = get_body_face_count(body)

            status = clean_one_chain_attempt(body, failed_signatures)

            faces_after = get_body_face_count(body)

            if status == "REMOVED":
                removed_global = True
                removed_this_pass = True
                failed_signatures = []

                log("[CHAIN PASS] Sucesso. Faces {0} -> {1}. Recalculando topologia.".format(
                    faces_before,
                    faces_after
                ))

                continue

            if status == "NO_SEEDS":
                log("[CHAIN PASS] Sem sementes pequenas. Encerrando etapa de cadeias.")
                break

            if status == "NO_MEMBERS":
                log("[CHAIN PASS] Sem membros de cadeia. Encerrando etapa de cadeias.")
                break

            if status == "NO_VALID_CHAIN":
                log("[CHAIN PASS] Nenhuma cadeia válida restante.")
                break

            if len(failed_signatures) > DEBUG_MAX_SEEDS_TO_PRINT:
                log("[CHAIN PASS] Muitas assinaturas falhadas. Encerrando ciclo.")
                break

            if faces_after == faces_before:
                continue

            break

        if not removed_this_pass:
            log("[CHAIN PASS] Nenhuma cadeia removida neste ciclo.")
            break

    return removed_global


# ============================================================
# LIMPEZA DE FUROS/REMANESCENTES SEM SEED
# ============================================================

def print_remaining_hole_components(components):
    hole_log("[HOLE] Componentes remanescentes encontrados: {0}".format(len(components)))

    max_print = DEBUG_MAX_COMPONENTS_TO_PRINT

    for i in range(len(components)):
        if i >= max_print:
            hole_log("[HOLE] ... componentes adicionais omitidos.")
            break

        comp = components[i]

        hole_log("[HOLE] Comp {0}: faces={1}, area_min={2:.3f}, area_max={3:.3f}".format(
            i + 1,
            len(comp),
            component_min_area(comp),
            component_max_area(comp)
        ))


def select_remaining_hole_variant(component):
    if component is None:
        return []

    size = len(component)

    if size == 0:
        return []

    if size == 1:
        if ALLOW_SINGLE_FACE_HOLE_FILL:
            return component
        return []

    return component


def try_remaining_hole_component(component, body):
    if component is None:
        return False

    if len(component) == 0:
        return False

    # Recuperação adicional para dentes que sobraram na etapa de furos.
    min_area = component_min_area(component)
    max_area = component_max_area(component)

    if min_area <= DENT_SEED_MAX_AREA_MM2 and max_area >= DENT_NEIGHBOR_MIN_AREA_MM2:
        seed = component[0]

        for i in range(len(component)):
            if record_area(component[i]) <= DENT_SEED_MAX_AREA_MM2:
                seed = component[i]
                break

        ok_dent = try_dent_seed_neighbor_pairs(
            seed,
            component,
            component,
            body,
            "furo/remanescente dente"
        )

        if ok_dent:
            return True

    variant = select_remaining_hole_variant(component)

    if len(variant) == 0:
        return False

    desc = "furo/remanescente | faces={0}, area_min={1:.3f}, area_max={2:.3f} em {3}".format(
        len(variant),
        component_min_area(variant),
        component_max_area(variant),
        safe_name(body)
    )

    return try_fill_records(
        variant,
        desc,
        body,
        ALLOW_SINGLE_FACE_HOLE_FILL
    )


def clean_remaining_holes_once(body, failed_signatures):
    protected = get_protected_faces(body)
    candidates = collect_remaining_hole_records(body, protected)

    hole_log("[HOLE] Candidatas remanescentes: {0}, protegidas={1}".format(
        len(candidates),
        len(protected)
    ))

    if len(candidates) == 0:
        return "NO_CANDIDATES"

    components = build_connected_components(
        candidates,
        REMAINING_HOLE_MAX_COMPONENT_FACES
    )

    print_remaining_hole_components(components)

    if len(components) == 0:
        return "NO_COMPONENTS"

    for i in range(len(components)):
        comp = components[i]

        if len(comp) > REMAINING_HOLE_MAX_COMPONENT_FACES:
            continue

        sig = chain_signature(comp)

        if signature_in_list(sig, failed_signatures):
            continue

        hole_log("[HOLE] Tentando componente {0}/{1}: faces={2}, assinatura={3}".format(
            i + 1,
            len(components),
            len(comp),
            sig
        ))

        ok = try_remaining_hole_component(comp, body)

        if ok:
            return "REMOVED"

        failed_signatures.append(sig)
        return "FAILED"

    return "NO_VALID_COMPONENT"


def clean_remaining_holes(body):
    if not ENABLE_REMAINING_HOLE_CLEAN:
        return False

    log("")
    log("------------------------------------------------------------")
    log("[ETAPA 4] Limpeza de furos/remanescentes sem seed")
    log("------------------------------------------------------------")

    removed_global = False
    attempts = 0
    failed_signatures = []

    for pass_id in range(REMAINING_HOLE_CLEAN_PASSES):
        log("")
        log("[HOLE PASS] Corpo '{0}' | ciclo {1}/{2}".format(
            safe_name(body),
            pass_id + 1,
            REMAINING_HOLE_CLEAN_PASSES
        ))

        removed_this_pass = False

        while attempts < MAX_REMAINING_HOLE_ATTEMPTS:
            attempts = attempts + 1

            faces_before = get_body_face_count(body)

            status = clean_remaining_holes_once(body, failed_signatures)

            faces_after = get_body_face_count(body)

            if status == "REMOVED":
                removed_global = True
                removed_this_pass = True
                failed_signatures = []

                log("[HOLE PASS] Sucesso. Faces {0} -> {1}. Recalculando topologia.".format(
                    faces_before,
                    faces_after
                ))

                continue

            if status == "NO_CANDIDATES":
                log("[HOLE PASS] Sem candidatas remanescentes.")
                break

            if status == "NO_COMPONENTS":
                log("[HOLE PASS] Sem componentes remanescentes.")
                break

            if status == "NO_VALID_COMPONENT":
                log("[HOLE PASS] Nenhum componente remanescente válido.")
                break

            if len(failed_signatures) > DEBUG_MAX_COMPONENTS_TO_PRINT:
                log("[HOLE PASS] Muitas assinaturas falhadas. Encerrando.")
                break

            if faces_after == faces_before:
                continue

            break

        if not removed_this_pass:
            log("[HOLE PASS] Nenhum furo/remanescente removido neste ciclo.")
            break

    return removed_global


# ============================================================
# PIPELINE POR CORPO
# ============================================================

def clean_body(body):
    if body is None:
        return

    log("")
    log("============================================================")
    log("[START] Limpando corpo: {0}".format(safe_name(body)))
    log("Faces iniciais: {0}".format(get_body_face_count(body)))
    log("============================================================")

    # --------------------------------------------------------
    # ETAPA 1 - Raios
    # --------------------------------------------------------
    if ENABLE_ROUND_CLEAN:
        log("")
        log("------------------------------------------------------------")
        log("[ETAPA 1] Remoção incremental de raios")
        log("------------------------------------------------------------")

        clean_rounds_incremental(body)

        log("[ETAPA 1] Faces após raios: {0}".format(
            get_body_face_count(body)
        ))

    # --------------------------------------------------------
    # ETAPA 2 - Arestas antes da limpeza de furos/cadeias
    # --------------------------------------------------------
    if ENABLE_PRE_CHAIN_EDGE_CLEAN:
        clean_residual_edges(body, "ETAPA 2 - pré-cadeias")

        log("[ETAPA 2] Faces após arestas pré-cadeias: {0}".format(
            get_body_face_count(body)
        ))

    # --------------------------------------------------------
    # ETAPA 3 - Cadeias com seed
    # --------------------------------------------------------
    if ENABLE_FEATURE_CHAIN_CLEAN:
        log("")
        log("------------------------------------------------------------")
        log("[ETAPA 3] Limpeza por cadeias conectadas")
        log("------------------------------------------------------------")

        clean_feature_chains(body)

        log("[ETAPA 3] Faces após cadeias: {0}".format(
            get_body_face_count(body)
        ))

    # --------------------------------------------------------
    # ETAPA 4 - Furos/remanescentes sem seed
    # --------------------------------------------------------
    if ENABLE_REMAINING_HOLE_CLEAN:
        clean_remaining_holes(body)

        log("[ETAPA 4] Faces após furos/remanescentes: {0}".format(
            get_body_face_count(body)
        ))

    # --------------------------------------------------------
    # ETAPA 5 - Arestas finais
    # --------------------------------------------------------
    if ENABLE_FINAL_EDGE_CLEAN:
        clean_residual_edges(body, "ETAPA 5 - final")

        log("[ETAPA 5] Faces após arestas finais: {0}".format(
            get_body_face_count(body)
        ))

    log("[END] Corpo finalizado: {0}".format(safe_name(body)))


# ============================================================
# PIPELINE ROOT
# ============================================================

def clean_all_root_bodies():
    log("")
    log("============================================================")
    log("[START] {0}".format(SCRIPT_VERSION))
    log("[LOG] Arquivo: {0}".format(get_debug_log_path()))
    log("[CONFIG] filtros={0} | match_component_path={1} | process_hidden={2}".format(
        BODY_NAME_FILTERS,
        BODY_FILTER_MATCH_COMPONENT_PATH,
        PROCESS_HIDDEN_BODIES
    ))
    log("============================================================")

    bodies = get_root_bodies()
    
    #result = FixExtraEdges.FindAndFix()
    
    if len(bodies) == 0:
        log("[ERRO] Nenhum corpo encontrado na arvore.")
        return

    selected_bodies = []
    skipped_filter = 0
    skipped_hidden = 0
    skipped_invalid = 0

    for i in range(len(bodies)):
        body = bodies[i]

        if body is None:
            skipped_invalid = skipped_invalid + 1
            continue

        if not body_is_alive_light(body):
            skipped_invalid = skipped_invalid + 1
            log("[SKIP] Corpo invalido/sem faces: {0}".format(safe_name(body)))
            continue

        if (not PROCESS_HIDDEN_BODIES) and (not body_is_visible(body)):
            skipped_hidden = skipped_hidden + 1
            log("[SKIP] Corpo oculto: {0}".format(safe_name(body)))
            continue

        if body_passes_name_filter(body):
            selected_bodies.append(body)
            log("[SELECT] {0} | path={1}".format(
                safe_name(body),
                body_parent_path_text(body)
            ))
        else:
            skipped_filter = skipped_filter + 1
            log("[SKIP] Corpo ignorado pelo filtro: {0} | path={1}".format(
                safe_name(body),
                body_parent_path_text(body)
            ))

    log("")
    log("============================================================")
    log("[ROOT] Corpos encontrados na arvore: {0}".format(len(bodies)))
    log("[ROOT] Selecionados para limpeza: {0}".format(len(selected_bodies)))
    log("[ROOT] Ignorados por filtro: {0}".format(skipped_filter))
    log("[ROOT] Ignorados ocultos: {0}".format(skipped_hidden))
    log("[ROOT] Ignorados invalidos: {0}".format(skipped_invalid))
    log("============================================================")

    for i in range(len(selected_bodies)):
        body = selected_bodies[i]

        try:
            if not body_is_alive_light(body):
                log("[SKIP] Corpo nao esta mais valido antes do processamento: {0}".format(
                    safe_name(body)
                ))
                continue

            log("")
            log("[ROOT] Processando {0}/{1}: {2}".format(
                i + 1,
                len(selected_bodies),
                safe_name(body)
            ))

            clean_body(body)
        except Exception as e:
            log("[ERRO] Falha geral limpando corpo '{0}': {1}".format(
                safe_name(body),
                e
            ))

    log("")
    log("============================================================")
    log("[DONE] Pipeline de limpeza finalizado.")
    log("[DONE] Log: {0}".format(get_debug_log_path()))
    log("============================================================")


# EXECUÇÃO
# ============================================================

try:
    clean_all_root_bodies()
except Exception as main_error:
    log("[FATAL] Erro geral no pipeline de limpeza: {0}".format(main_error))
