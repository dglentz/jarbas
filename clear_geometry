def _ensure_debug_log_dir():
    if not LOG_TO_FILE:
        return

    try:
        if os is None:
            return
    except:
        return

    try:
        if not os.path.exists(DEBUG_LOG_DIR):
            os.makedirs(DEBUG_LOG_DIR)
    except:
        pass


def get_debug_log_path():
    global _DEBUG_LOG_PATH

    if _DEBUG_LOG_PATH is not None:
        return _DEBUG_LOG_PATH

    try:
        if datetime is not None:
            stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        else:
            stamp = "manual"
    except:
        stamp = "manual"

    try:
        if os is not None:
            _DEBUG_LOG_PATH = os.path.join(DEBUG_LOG_DIR, DEBUG_LOG_PREFIX + stamp + ".txt")
        else:
            _DEBUG_LOG_PATH = r"C:\temp\clean_debug.txt"
    except:
        _DEBUG_LOG_PATH = r"C:\temp\clean_debug.txt"

    return _DEBUG_LOG_PATH


def log(msg):
    try:
        line = str(msg)
    except:
        line = "<LOG_FORMAT_ERROR>"

    try:
        print(line)
    except:
        pass

    if not LOG_TO_FILE:
        return

    try:
        _ensure_debug_log_dir()
        path = get_debug_log_path()
        f = open(path, "a")
        try:
            f.write(line + "\n")
        finally:
            f.close()
    except:
        pass


