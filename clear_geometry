def list_from_iterable(obj):
    if obj is None:
        return []

    try:
        return list(obj)
    except:
        pass

    out = []

    try:
        for item in obj:
            out.append(item)

        return out
    except:
        pass

    try:
        count = obj.Count
        count = count() if callable(count) else count

        for i in range(int(count)):
            try:
                out.append(obj[i])
            except:
                pass

        return out
    except:
        pass

    try:
        length = len(obj)

        for i in range(int(length)):
            try:
                out.append(obj[i])
            except:
                pass

        return out
    except:
        return out


